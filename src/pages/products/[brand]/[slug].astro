---
import BaseLayout from '../../../layouts/BaseLayout.astro'

export const prerender = true;

// getStaticPaths runs at module scope — use dynamic import with fallback
export async function getStaticPaths() {
  let buildDataProducts: Array<{ slug: string; brandSlug?: string }> = [];
  try {
    const { default: data } = await import('../../../data/build-data.json');
    buildDataProducts = data.products || [];
  } catch { /* build-data.json not generated yet — no static pages */ }
  return buildDataProducts.map((p) => ({ params: { brand: p.brandSlug ?? 'other', slug: p.slug } }));
}

const { brand, slug } = Astro.params;
if (!brand || !slug) return Astro.redirect('/404');

// Load from build-data (primary data source for static prerender)
let product: { name: string; summary: string | null; description: string | null } | null = null;
let siteName = 'YourCompany';
let brandName = brand;

try {
  const { default: data } = await import('../../../data/build-data.json');
  const found = (data.products || []).find((p: any) => p.slug === slug);
  if (found) {
    product = { name: found.name, summary: found.summary || null, description: found.description || null };
    if (data.settings?.site_name) siteName = data.settings.site_name;
  }
  const brandObj = (data.productCategories || []).find((c: any) => c.slug === brand);
  brandName = brandObj?.name || brand;
} catch { /* no build-data */ }
---

<BaseLayout title={product ? product.name : 'Product'} description={product?.summary || undefined}>
  {product && (
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Product",
        "name": product.name,
        "description": product.summary || product.description || "",
        "url": Astro.url.href,
        "brand": { "@type": "Brand", "name": siteName }
      },
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL("/", Astro.url).href },
          { "@type": "ListItem", "position": 2, "name": "Products", "item": new URL("/products", Astro.url).href },
          { "@type": "ListItem", "position": 3, "name": brandName, "item": new URL(`/products/${brand}`, Astro.url).href },
          { "@type": "ListItem", "position": 4, "name": product.name, "item": Astro.url.href }
        ]
      }
    ])} />
  )}
  <section style="padding: 4rem 0;">
    <div class="container" style="max-width: 48rem;">
      {product ? (
        <>
          <h1 class="heading-1" style="margin-bottom: 1rem;">{product.name}</h1>
          {product.summary && <p style="color: var(--color-text-secondary); font-size: 1.0625rem; margin-bottom: 2rem; line-height: 1.8;">{product.summary}</p>}
          {product.description && <div style="color: var(--color-text-secondary); line-height: 1.8;">{product.description}</div>}

          <!-- Quote Request Form -->
          <div id="quote-section" style="margin-top: 3rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
            <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem;">Request a Quote</h2>
            <p style="font-size: 0.875rem; color: var(--color-text-tertiary); margin-bottom: 1.5rem;">Interested in this product? Fill out the form below and our team will get back to you.</p>

            <form id="quote-form" style="display: flex; flex-direction: column; gap: 1rem; max-width: 36rem; padding: 1.5rem; background: var(--color-surface-subtle); border-radius: var(--radius-xl); border: 1px solid var(--color-border);">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                  <label for="quote-name" style="font-size: 0.8125rem; font-weight: 500;">Name</label>
                  <input id="quote-name" type="text" name="name" placeholder="Your name" style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                  <label for="quote-company" style="font-size: 0.8125rem; font-weight: 500;">Company</label>
                  <input id="quote-company" type="text" name="company" placeholder="Your company" style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
                </div>
              </div>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                  <label for="quote-email" style="font-size: 0.8125rem; font-weight: 500;">Email *</label>
                  <input id="quote-email" type="email" name="email" required placeholder="your@email.com" style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                  <label for="quote-phone" style="font-size: 0.8125rem; font-weight: 500;">Phone</label>
                  <input id="quote-phone" type="tel" name="phone" placeholder="+1 (555) 000-0000" style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
                </div>
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <label for="quote-product" style="font-size: 0.8125rem; font-weight: 500;">Product</label>
                <input id="quote-product" type="text" name="product" readonly value={product.name} style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface); opacity: 0.7;" />
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <label for="quote-message" style="font-size: 0.8125rem; font-weight: 500;">Message *</label>
                <textarea id="quote-message" name="message" required rows={4} placeholder="Tell us about your requirements, quantity, timeline, etc." style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; resize: vertical; background: var(--color-surface);"></textarea>
              </div>
              <div id="quote-form-msg"></div>
              <button type="submit" id="quote-submit-btn" style="padding: 0.625rem 1.25rem; border-radius: var(--radius-md); font-size: 0.875rem; font-weight: 500; background: var(--color-brand-600); color: var(--color-text-inverse); border: none; cursor: pointer; align-self: flex-start;">Submit Inquiry</button>
            </form>
          </div>
        </>
      ) : (<p style="color: var(--color-text-tertiary);">Product not found.</p>)}
    </div>
  </section>
</BaseLayout>

<script>
(function() {
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('quote-submit-btn') as HTMLButtonElement | null;
  const msgEl = document.getElementById('quote-form-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !msgEl || !form) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    msgEl.innerHTML = '';

    const fd = new FormData(form);
    try {
      const res = await fetch('/api/quote-requests', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: fd.get('email'),
          name: fd.get('name') || null,
          company: fd.get('company') || null,
          phone: fd.get('phone') || null,
          product: fd.get('product') || null,
          message: fd.get('message'),
        }),
      });

      if (res.ok) {
        form.reset();
        // Re-set the readonly product field
        const productInput = form.querySelector('input[name="product"]') as HTMLInputElement;
        if (productInput) productInput.value = productInput.defaultValue;
        msgEl.innerHTML = '<p style="color: var(--color-success-text); font-size: 0.875rem; margin: 0;">Thank you! Your inquiry has been submitted. We will contact you shortly.</p>';
        submitBtn.style.display = 'none';
      } else {
        const data = await res.json().catch(() => ({})) as Record<string, string>;
        msgEl.innerHTML = `<p style="color: var(--color-danger-text); font-size: 0.875rem; margin: 0;">${data.error || 'Failed to submit inquiry'}</p>`;
      }
    } catch {
      msgEl.innerHTML = '<p style="color: var(--color-danger-text); font-size: 0.875rem; margin: 0;">Network error. Please try again.</p>';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Inquiry';
    }
  });
})();
</script>
