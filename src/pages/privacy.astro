---
import BaseLayout from '../layouts/BaseLayout.astro'
import { sanitizeHtml } from '../lib/sanitize'

export const prerender = true;

let buildData: { settings: Record<string, string>; pages?: Record<string, Record<string, Record<string, string>>> } = { settings: {} };
try {
  const { default: data } = await import('../data/build-data.json');
  if (data) buildData = data;
} catch { /* build-data.json not generated yet */ }

const siteName = buildData.settings.site_name || 'YourCompany';
const privacyContent = buildData.pages?.privacy?.content || {};
const title = privacyContent.title || 'Privacy Policy';
const body = privacyContent.body || '<p>Privacy policy content coming soon.</p>';
const lastUpdated = privacyContent.last_updated || '';
---

<BaseLayout title={title} buildData={buildData}>
  <section style="padding: 4rem 0;">
    <div class="container" style="max-width: 48rem;">
      <h1 class="heading-1" style="margin-bottom: 2rem;">{title}</h1>
      <div set:html={sanitizeHtml(body)} />
      {lastUpdated && <p style="margin-top: 3rem; color: var(--color-text-tertiary); font-size: 0.875rem;">Last updated: {lastUpdated}</p>}
    </div>
  </section>
</BaseLayout>
