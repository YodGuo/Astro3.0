---
import BaseLayout from '../layouts/BaseLayout.astro'

export const prerender = true
---

<BaseLayout title="Server Error">
  <section style="padding: 6rem 0; text-align: center;">
    <div class="container" style="max-width: 560px; margin: 0 auto;">
      <h1 style="font-size: 3rem; font-weight: 700; margin-bottom: 1rem;">500</h1>
      <p style="font-size: 1.25rem; color: var(--color-text-tertiary); margin-bottom: 2rem;">
        Something went wrong on our end. Please try again later.
      </p>
      <a href="/" style="display: inline-block; padding: 0.75rem 1.5rem; background: var(--color-brand-600); color: var(--color-text-inverse); border-radius: var(--radius-md); text-decoration: none; font-weight: 500;">
        Back to Homepage
      </a>
    </div>
  </section>
</BaseLayout>
