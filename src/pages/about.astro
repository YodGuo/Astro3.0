---
import BaseLayout from '../layouts/BaseLayout.astro'
import { sanitizeHtml } from '../lib/sanitize'

export const prerender = true;

// Load build-data for prerendered branding
let buildData: { settings: Record<string, string>; pages?: Record<string, Record<string, Record<string, string>>> } = { settings: {} };
try {
  const { default: data } = await import('../data/build-data.json');
  if (data) buildData = data;
} catch { /* build-data.json not generated yet */ }

const siteName = buildData.settings.site_name || 'YourCompany';
const aboutHero = buildData.pages?.about?.hero || {};
const aboutStory = buildData.pages?.about?.story || {};
const aboutContact = buildData.pages?.about?.contact || {};

const storyStyle = "color: var(--color-text-secondary); margin-bottom: 1.5rem; line-height: 1.8;";
const storyHtml = aboutStory.body
  ? aboutStory.body.split('\n').filter(Boolean).map(p => `<p style="${storyStyle}">${sanitizeHtml(p)}</p>`).join('')
  : `<p style="${storyStyle}">${siteName} has been a leading provider of uninterruptible power supply (UPS) systems and power management solutions for over 20 years. We serve businesses across data centers, healthcare, industrial, and government sectors.</p><p style="${storyStyle}">Our mission is to ensure your critical operations never experience downtime. From small office setups to enterprise data centers, we deliver reliable, efficient, and scalable power continuity solutions.</p>`;
---

<BaseLayout title="About" buildData={buildData}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": `About ${siteName}`,
    "description": `Learn about ${siteName} — a professional B2B power solutions provider specializing in UPS systems, PDUs, and power distribution products.`,
    "url": Astro.url.href,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL("/", Astro.url).href },
        { "@type": "ListItem", "position": 2, "name": "About", "item": Astro.url.href }
      ]
    }
  })} />
  <section style="padding: 4rem 0;">
    <div class="container" style="max-width: 48rem;">
      <h1 class="heading-1" style="margin-bottom: 2rem;">{aboutHero.title ? aboutHero.title.replace('{site_name}', siteName) : `About ${siteName}`}</h1>
      <div set:html={storyHtml} />
      <div id="contact" style="margin-top: 3rem;">
        <h2 class="heading-2" style="margin-bottom: 1rem;">Contact Us</h2>
        <div class="card">
          <p style="margin-bottom: 0.5rem;"><strong>Email:</strong> {aboutContact.email || 'info@yourcompany.com'}</p>
          <p style="margin-bottom: 0.5rem;"><strong>Phone:</strong> {aboutContact.phone || '+1 (555) 123-4567'}</p>
          <p><strong>Address:</strong> {aboutContact.address || '123 Power Avenue, Tech City, TC 12345'}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
