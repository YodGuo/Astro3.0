---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getEnv } from '../../../lib/env'
import PageContentSection from '../../../components/admin/settings/PageContentSection.astro'
import PageVisibilitySection from '../../../components/admin/settings/PageVisibilitySection.astro'
import SiteBrandingSection from '../../../components/admin/settings/SiteBrandingSection.astro'
import DomainIsolationSection from '../../../components/admin/settings/DomainIsolationSection.astro'
import ThemeSection from '../../../components/admin/settings/ThemeSection.astro'
import AnalyticsSettingsSection from '../../../components/admin/settings/AnalyticsSettingsSection.astro'
import NotificationLogs from '../../../components/admin/settings/NotificationLogs'
import SocialLinksManager from '../../../components/admin/settings/SocialLinksManager'
import NotificationDashboard from '../../../components/admin/settings/NotificationDashboard'
import NotificationChannels from '../../../components/admin/settings/NotificationChannels'
import NotificationTemplates from '../../../components/admin/settings/NotificationTemplates'

export const prerender = false;

interface SettingRow {
  key: string;
  value: string;
}

let settings: Record<string, boolean> = {};
let brandingSettings: Record<string, string> = {};

try {
  const env = await getEnv();
  const d1 = env.DB;
  if (d1) {
    const rows = await d1.prepare("SELECT key, value FROM site_settings").all() as { results: SettingRow[] };
    for (const row of rows.results) {
      if (row.value === 'true' || row.value === 'false') {
        settings[row.key] = row.value === 'true';
      } else {
        brandingSettings[row.key] = row.value;
      }
    }
  }
} catch { /* D1 not available */ }

const settingGroups = [
  {
    title: 'Core Pages',
    items: [
      { key: 'homepage_enabled', label: 'Homepage', description: 'Show the main landing page (/)' },
      { key: 'about_enabled', label: 'About Page', description: 'Show /about page to visitors' },
      { key: 'services_enabled', label: 'Services Page', description: 'Show /services page to visitors' },
    ],
  },
  {
    title: 'Products & News',
    items: [
      { key: 'products_enabled', label: 'Products Page', description: 'Show /products page and product detail pages' },
      { key: 'news_enabled', label: 'News Page', description: 'Show /news page and article detail pages' },
    ],
  },
  {
    title: 'Solutions',
    items: [
      { key: 'solutions_enabled', label: 'Solutions (All)', description: 'Master switch — hide all solution pages and nav link' },
      { key: 'solutions_data-centers_enabled', label: 'Data Centers', description: 'Show /solutions/data-centers page' },
      { key: 'solutions_healthcare_enabled', label: 'Healthcare', description: 'Show /solutions/healthcare page' },
      { key: 'solutions_industrial_enabled', label: 'Industrial', description: 'Show /solutions/industrial page' },
      { key: 'solutions_telecommunications_enabled', label: 'Telecommunications', description: 'Show /solutions/telecommunications page' },
      { key: 'solutions_finance_enabled', label: 'Finance', description: 'Show /solutions/finance page' },
      { key: 'solutions_government_enabled', label: 'Government', description: 'Show /solutions/government page' },
    ],
  },
];
---

<AdminLayout title="Site Settings — Admin" currentPath="/admin/settings">
  <div>
    <h1 class="heading-1" style="margin-bottom: 0.5rem;">Site Settings</h1>
    <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">Control which pages are visible to visitors and configure notifications.</p>

    <!-- Page Content -->
    <PageContentSection />

    <!-- Site Branding -->
    <SiteBrandingSection settings={brandingSettings} />

    <!-- Domain Isolation -->
    <DomainIsolationSection settings={brandingSettings} />

    <!-- Theme -->
    <ThemeSection settings={brandingSettings} />

    <!-- Analytics -->
    <AnalyticsSettingsSection settings={brandingSettings} />

    <!-- Page Visibility -->
    <PageVisibilitySection settings={settings} settingGroups={settingGroups} />

    <!-- Social Links -->
    <SocialLinksManager client:load />

    <!-- Notification Dashboard -->
    <NotificationDashboard client:load />

    <!-- Notification Channels -->
    <NotificationChannels client:load />

    <!-- Notification Logs -->
    <NotificationLogs client:load />

    <!-- Notification Templates -->
    <NotificationTemplates client:load />
  </div>
</AdminLayout>

<style>
  .toggle-switch {
    position: relative;
    display: inline-block;
    width: 48px;
    height: 26px;
    flex-shrink: 0;
  }
  .toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }
  .toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: var(--color-surface-muted);
    transition: 0.2s;
    border-radius: var(--radius-full);
  }
  .toggle-slider:before {
    position: absolute;
    content: "";
    height: 20px;
    width: 20px;
    left: 3px;
    bottom: 3px;
    background-color: var(--color-text-inverse);
    transition: 0.2s;
    border-radius: 50%;
  }
  input:checked + .toggle-slider {
    background-color: var(--color-brand-500);
  }
  input:checked + .toggle-slider:before {
    transform: translateX(22px);
  }

  .modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }
  .modal-content {
    width: 100%;
    max-width: 32rem;
    max-height: 90vh;
    overflow-y: auto;
    padding: 2rem;
  }
  .btn-secondary {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 500;
    background: var(--color-surface-muted);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    cursor: pointer;
  }
  .btn-secondary:hover {
    background: var(--color-border);
  }
  .card {
    background: var(--color-surface, white);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: var(--radius-lg);
    padding: 1rem;
  }
</style>
