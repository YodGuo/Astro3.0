---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { newsPosts } from '../../../lib/db/schema'
import { sql } from 'drizzle-orm'

export const prerender = false;

let articles: Array<{ id: string; title: string; status: string | null; createdAt: number | null; slug: string }> = [];

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    articles = await db.select({ id: newsPosts.id, title: newsPosts.title, status: newsPosts.status, createdAt: newsPosts.createdAt, slug: newsPosts.slug }).from(newsPosts).orderBy(sql`${newsPosts.createdAt} desc`) as unknown as Array<{ id: string; title: string; status: string | null; createdAt: number | null; slug: string }>;
  }
} catch { /* D1 not available */ }
---

<AdminLayout title="News — Admin" currentPath="/admin/news">
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
      <h1 class="heading-1">News Articles</h1>
      <a href="/admin/news/new" class="btn-primary" style="text-decoration: none; font-size: 0.875rem; padding: 0.5rem 1rem;">+ New Article</a>
    </div>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Title</th><th>Status</th><th>Date</th></tr></thead>
        <tbody>
          {articles.length > 0 ? articles.map((a) => (
            <tr><td><a href={`/admin/news/${a.id}/edit`} style="color: var(--color-brand-600); text-decoration: none;">{a.title}</a></td><td><span class="badge-gray">{a.status || 'draft'}</span></td><td>{a.createdAt ? new Date(a.createdAt).toLocaleDateString() : '—'}</td></tr>
          )) : (<tr><td colspan="3" class="empty-cell">No articles yet.</td></tr>)}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<style>
  .admin-table-wrap { overflow: hidden; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
  .admin-table { width: 100%; font-size: 0.875rem; border-collapse: collapse; }
  .admin-table thead tr { border-bottom: 1px solid var(--color-border); background: var(--color-surface-subtle); }
  .admin-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 500; }
  .admin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .empty-cell { padding: 2rem 1rem !important; text-align: center; color: var(--color-text-tertiary); }
</style>
