---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { comments } from '../../../lib/db/schema'
import { sql, count } from 'drizzle-orm'

export const prerender = false;

const PAGE_SIZE = 20;
const currentPage = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1') || 1);
const offset = (currentPage - 1) * PAGE_SIZE;

let commentsList: Array<{ id: string; authorName: string; content: string; status: string | null; createdAt: number | null; postId: string | null }> = [];
let totalItems = 0;

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    const [{ total }] = await db.select({ total: count() }).from(comments);
    totalItems = total;
    commentsList = await db.select({ id: comments.id, authorName: comments.authorName, content: comments.content, status: comments.status, createdAt: comments.createdAt, postId: comments.postId }).from(comments).orderBy(sql`${comments.createdAt} desc`).limit(PAGE_SIZE).offset(offset) as Array<{ id: string; authorName: string; content: string; status: string | null; createdAt: number | null; postId: string | null }>;
  }
} catch { /* D1 not available */ }

const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));
const basePath = '/admin/news/comments';
---

<AdminLayout title="Comments — Admin" currentPath="/admin/news/comments">
  <div>
    <h1 class="heading-1" style="margin-bottom: 1.5rem;">Comment Moderation</h1>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Author</th><th>Comment</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody id="comments-tbody">
          {commentsList.length > 0 ? commentsList.map((c) => (
            <tr data-id={c.id}>
              <td style="white-space: nowrap;">{c.authorName}</td>
              <td style="max-width: 20rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title={c.content}>{c.content}</td>
              <td><span class="badge-gray" data-role="status">{c.status || 'pending'}</span></td>
              <td style="white-space: nowrap;">{c.createdAt ? new Date(c.createdAt).toLocaleDateString() : '—'}</td>
              <td style="white-space: nowrap;">
                <button class="btn-action btn-approve" data-action="approve" disabled={c.status === 'approved'}>Approve</button>
                <button class="btn-action btn-reject" data-action="reject" disabled={c.status === 'rejected'}>Reject</button>
                <button class="btn-action btn-delete" data-action="delete">Delete</button>
              </td>
            </tr>
          )) : (<tr><td colspan="5" class="empty-cell">No comments to moderate.</td></tr>)}
        </tbody>
      </table>
    </div>
    {totalPages > 1 && (
      <nav class="pagination">
        {currentPage > 1 && <a href={`${basePath}?page=${currentPage - 1}`} class="page-btn">&larr; Prev</a>}
        <span class="page-info">Page {currentPage} of {totalPages} ({totalItems} total)</span>
        {currentPage < totalPages && <a href={`${basePath}?page=${currentPage + 1}`} class="page-btn">Next &rarr;</a>}
      </nav>
    )}
  </div>
</AdminLayout>

<script>
document.getElementById('comments-tbody')?.addEventListener('click', async (e) => {
  const btn = (e.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null;
  if (!btn) return;

  const action = btn.dataset.action;
  const row = btn.closest('tr') as HTMLTableRowElement | null;
  if (!row) return;

  const id = row.dataset.id;
  if (!id) return;

  // Disable all buttons in this row during the request
  const buttons = row.querySelectorAll('button[data-action]');
  buttons.forEach(b => { (b as HTMLButtonElement).disabled = true; });

  try {
    if (action === 'delete') {
      if (!confirm('Are you sure you want to delete this comment?')) {
        buttons.forEach(b => { (b as HTMLButtonElement).disabled = false; });
        return;
      }
      const res = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
      if (res.ok) {
        row.remove();
      } else {
        const data = await res.json().catch(() => ({})) as Record<string, string>;
        alert(data.error || 'Failed to delete comment');
        buttons.forEach(b => { (b as HTMLButtonElement).disabled = false; });
      }
    } else {
      const status = action === 'approve' ? 'approved' : 'rejected';
      const res = await fetch(`/api/comments/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
      });
      if (res.ok) {
        const badge = row.querySelector('[data-role="status"]') as HTMLElement | null;
        if (badge) badge.textContent = status;
        // Update button disabled states
        const approveBtn = row.querySelector('[data-action="approve"]') as HTMLButtonElement | null;
        const rejectBtn = row.querySelector('[data-action="reject"]') as HTMLButtonElement | null;
        if (approveBtn) approveBtn.disabled = status === 'approved';
        if (rejectBtn) rejectBtn.disabled = status === 'rejected';
      } else {
        const data = await res.json().catch(() => ({})) as Record<string, string>;
        alert(data.error || `Failed to ${action} comment`);
        buttons.forEach(b => { (b as HTMLButtonElement).disabled = false; });
      }
    }
  } catch {
    alert('Network error');
    buttons.forEach(b => { (b as HTMLButtonElement).disabled = false; });
  }
});
</script>

<style>
  .admin-table-wrap { overflow: hidden; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
  .admin-table { width: 100%; font-size: 0.875rem; border-collapse: collapse; }
  .admin-table thead tr { border-bottom: 1px solid var(--color-border); background: var(--color-surface-subtle); }
  .admin-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 500; }
  .admin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .empty-cell { padding: 2rem 1rem !important; text-align: center; color: var(--color-text-tertiary); }

  .btn-action {
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    cursor: pointer;
    margin-right: 0.25rem;
    transition: background 0.15s, color 0.15s;
  }
  .btn-action:hover:not(:disabled) { background: var(--color-surface-subtle); }
  .btn-action:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-approve:hover:not(:disabled) { background: var(--color-success-bg); color: var(--color-success-text); border-color: var(--color-success-border); }
  .btn-reject:hover:not(:disabled) { background: var(--color-danger-bg); color: var(--color-danger-text); border-color: var(--color-danger-border); }
  .btn-delete:hover:not(:disabled) { background: var(--color-danger-bg); color: var(--color-danger-text); border-color: var(--color-danger-border); }

  .pagination {
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--color-border-subtle);
  }
  .page-btn {
    padding: 0.375rem 0.875rem; border-radius: var(--radius-md); font-size: 0.8125rem; font-weight: 500;
    border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary);
    text-decoration: none; transition: background 0.15s;
  }
  .page-btn:hover { background: var(--color-surface-subtle); color: var(--color-text-primary); }
  .page-info { font-size: 0.8125rem; color: var(--color-text-tertiary); }
</style>
