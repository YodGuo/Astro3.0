---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { productCategories } from '../../../lib/db/schema'
import { sql } from 'drizzle-orm'

export const prerender = false;

let categoriesList: Array<{ id: string; name: string; slug: string; parentId: string | null; order: number; productCount: number }> = [];

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    categoriesList = await db
      .select({
        id: productCategories.id,
        name: productCategories.name,
        slug: productCategories.slug,
        parentId: productCategories.parentId,
        order: productCategories.order,
        productCount: sql<number>`(SELECT COUNT(*) FROM products WHERE category_id = product_categories.id AND published = 1)`.as("product_count"),
      })
      .from(productCategories)
      .orderBy(productCategories.order, productCategories.name) as Array<{ id: string; name: string; slug: string; parentId: string | null; order: number; productCount: number }>;
  }
} catch { /* D1 not available */ }
---

<AdminLayout title="Categories — Admin" currentPath="/admin/products/categories">
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
      <h1 class="heading-1" style="margin-bottom: 0;">Product Categories</h1>
      <button id="btn-create" class="btn-primary">+ New Category</button>
    </div>

    <!-- Create / Edit Modal -->
    <div id="cat-modal" class="modal-overlay" style="display: none;">
      <div class="modal-card">
        <h2 id="modal-title" style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Create Category</h2>
        <form id="cat-form" style="display: flex; flex-direction: column; gap: 0.75rem;">
          <input type="hidden" id="cat-id" name="id" value="" />
          <label style="font-size: 0.8125rem; font-weight: 500; color: var(--color-text-secondary);">Name</label>
          <input type="text" id="cat-name" name="name" required maxlength="100" placeholder="e.g. UPS Systems" style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
          <label style="font-size: 0.8125rem; font-weight: 500; color: var(--color-text-secondary);">Sort Order</label>
          <input type="number" id="cat-order" name="order" value="0" min="0" style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface); width: 6rem;" />
          <p id="modal-error" style="display: none; color: var(--color-danger-text); font-size: 0.8125rem; margin: 0;"></p>
          <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 0.5rem;">
            <button type="button" id="btn-cancel" class="btn-action">Cancel</button>
            <button type="submit" class="btn-primary" style="padding: 0.375rem 1rem; font-size: 0.8125rem;">Save</button>
          </div>
        </form>
      </div>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Name</th><th>Slug</th><th>Order</th><th>Products</th><th>Actions</th></tr></thead>
        <tbody id="cats-tbody">
          {categoriesList.length > 0 ? categoriesList.map((c) => (
            <tr data-id={c.id} data-name={c.name} data-order={String(c.order)}>
              <td style="font-weight: 500;">{c.name}</td>
              <td style="color: var(--color-text-tertiary); font-size: 0.8125rem;">{c.slug}</td>
              <td><span class="badge-gray">{c.order}</span></td>
              <td><span class="badge-gray">{c.productCount}</span></td>
              <td style="white-space: nowrap;">
                <button class="btn-action btn-edit" data-action="edit">Edit</button>
                <button class="btn-action btn-delete" data-action="delete">Delete</button>
              </td>
            </tr>
          )) : (<tr><td colspan="5" class="empty-cell">No categories yet.</td></tr>)}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
(function() {
  const modal = document.getElementById('cat-modal') as HTMLDivElement;
  const form = document.getElementById('cat-form') as HTMLFormElement;
  const titleEl = document.getElementById('modal-title') as HTMLHeadingElement;
  const idInput = document.getElementById('cat-id') as HTMLInputElement;
  const nameInput = document.getElementById('cat-name') as HTMLInputElement;
  const orderInput = document.getElementById('cat-order') as HTMLInputElement;
  const errorEl = document.getElementById('modal-error') as HTMLParagraphElement;
  const tbody = document.getElementById('cats-tbody') as HTMLTableSectionElement;

  function openModal(mode: 'create' | 'edit', id?: string, name?: string, order?: number) {
    titleEl.textContent = mode === 'create' ? 'Create Category' : 'Edit Category';
    idInput.value = id || '';
    nameInput.value = name || '';
    orderInput.value = order !== undefined ? String(order) : '0';
    errorEl.style.display = 'none';
    modal.style.display = 'flex';
    nameInput.focus();
  }

  function closeModal() { modal.style.display = 'none'; }

  document.getElementById('btn-create')?.addEventListener('click', () => openModal('create'));
  document.getElementById('btn-cancel')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.style.display = 'none';
    const name = nameInput.value.trim();
    if (!name) return;
    const order = parseInt(orderInput.value) || 0;

    const id = idInput.value;
    const isEdit = !!id;
    const url = isEdit ? `/api/product-categories/${id}` : '/api/product-categories';
    const method = isEdit ? 'PUT' : 'POST';

    try {
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, order }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json().catch(() => ({})) as Record<string, string>;
        errorEl.textContent = data.error || 'Failed to save category';
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.textContent = 'Network error';
      errorEl.style.display = 'block';
    }
  });

  tbody?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null;
    if (!btn) return;

    const action = btn.dataset.action;
    const row = btn.closest('tr') as HTMLTableRowElement | null;
    if (!row) return;

    const id = row.dataset.id;
    const name = row.dataset.name || '';
    const order = parseInt(row.dataset.order || '0');
    if (!id) return;

    if (action === 'edit') {
      openModal('edit', id, name, order);
      return;
    }

    if (action === 'delete') {
      const productCount = parseInt(row.querySelectorAll('.badge-gray')[1]?.textContent || '0');
      if (productCount > 0) {
        if (!confirm(`This category has ${productCount} product(s). Deleting will unlink them. Continue?`)) return;
      } else {
        if (!confirm('Delete this category?')) return;
      }

      btn.disabled = true;
      try {
        const res = await fetch(`/api/product-categories/${id}`, { method: 'DELETE' });
        if (res.ok) {
          row.remove();
        } else {
          const data = await res.json().catch(() => ({})) as Record<string, string>;
          alert(data.error || 'Failed to delete category');
          btn.disabled = false;
        }
      } catch {
        alert('Network error');
        btn.disabled = false;
      }
    }
  });
})();
</script>

<style>
  .btn-primary {
    padding: 0.5rem 1rem; border-radius: var(--radius-lg); font-size: 0.875rem; font-weight: 500;
    background: var(--color-brand-600, #2563eb); color: var(--color-text-inverse); border: none; cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.9; }

  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex;
    align-items: center; justify-content: center; z-index: 100;
  }
  .modal-card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-xl); padding: 1.5rem; width: 100%; max-width: 24rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  .admin-table-wrap { overflow: hidden; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
  .admin-table { width: 100%; font-size: 0.875rem; border-collapse: collapse; }
  .admin-table thead tr { border-bottom: 1px solid var(--color-border); background: var(--color-surface-subtle); }
  .admin-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 500; }
  .admin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .empty-cell { padding: 2rem 1rem !important; text-align: center; color: var(--color-text-tertiary); }

  .btn-action {
    padding: 0.25rem 0.625rem; border-radius: var(--radius-md); font-size: 0.75rem; font-weight: 500;
    border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary);
    cursor: pointer; margin-right: 0.25rem; transition: background 0.15s, color 0.15s;
  }
  .btn-action:hover:not(:disabled) { background: var(--color-surface-subtle); }
  .btn-action:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-edit:hover:not(:disabled) { background: var(--color-info-bg); color: var(--color-info-text); border-color: var(--color-info-border); }
  .btn-delete:hover:not(:disabled) { background: var(--color-danger-bg); color: var(--color-danger-text); border-color: var(--color-danger-border); }

  .badge-gray {
    display: inline-block; padding: 0.125rem 0.5rem; border-radius: var(--radius-full);
    font-size: 0.75rem; font-weight: 500; background: var(--color-surface-subtle);
    color: var(--color-text-secondary); border: 1px solid var(--color-border-subtle);
  }
</style>
