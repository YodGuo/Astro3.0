---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { solutions } from '../../../lib/db/schema'
import { sql } from 'drizzle-orm'

export const prerender = false;

let solutionList: Array<{ id: string; title: string; slug: string; industry: string }> = [];

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    solutionList = await db.select({ id: solutions.id, title: solutions.title, slug: solutions.slug, industry: solutions.industry }).from(solutions).orderBy(sql`${solutions.industry} asc`) as unknown as Array<{ id: string; title: string; slug: string; industry: string }>;
  }
} catch { /* D1 not available */ }
---

<AdminLayout title="Solutions — Admin" currentPath="/admin/solutions">
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
      <h1 class="heading-1">Solutions</h1>
      <a href="/admin/solutions/edit" class="btn-primary" style="text-decoration: none; font-size: 0.875rem; padding: 0.5rem 1rem;">+ New Solution</a>
    </div>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Title</th><th>Industry</th><th>Slug</th><th>Actions</th></tr></thead>
        <tbody>
          {solutionList.length > 0 ? solutionList.map((s) => (
            <tr>
              <td><a href={`/admin/solutions/edit?id=${s.id}`} style="color: var(--color-brand-600); text-decoration: none;">{s.title}</a></td>
              <td><span class="badge-gray">{s.industry}</span></td>
              <td style="color: var(--color-text-tertiary); font-size: 0.8125rem;">{s.slug}</td>
              <td style="white-space: nowrap;">
                <a href={`/admin/solutions/edit?id=${s.id}`} class="btn-action btn-edit">Edit</a>
                <button class="btn-action btn-delete" data-id={s.id} data-title={s.title}>Delete</button>
              </td>
            </tr>
          )) : (<tr><td colspan="4" class="empty-cell">No solutions yet.</td></tr>)}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
document.querySelectorAll<HTMLButtonElement>('.btn-delete').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id;
    const title = btn.dataset.title;
    if (!id || !confirm(`Delete solution "${title}"?`)) return;
    try {
      const res = await fetch(`/api/solutions/${id}`, { method: 'DELETE' });
      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json().catch(() => ({})) as Record<string, string>;
        alert(data.error || 'Failed to delete');
      }
    } catch {
      alert('Network error');
    }
  });
});
</script>

<style>
  .admin-table-wrap { overflow: hidden; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
  .admin-table { width: 100%; font-size: 0.875rem; border-collapse: collapse; }
  .admin-table thead tr { border-bottom: 1px solid var(--color-border); background: var(--color-surface-subtle); }
  .admin-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 500; }
  .admin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .empty-cell { padding: 2rem 1rem !important; text-align: center; color: var(--color-text-tertiary); }
  .badge-gray { display: inline-block; padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 500; background: var(--color-surface-muted); color: var(--color-text-tertiary); }
  .btn-action { padding: 0.25rem 0.625rem; border-radius: var(--radius-md); font-size: 0.75rem; font-weight: 500; border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); cursor: pointer; transition: background 0.15s, color 0.15s; text-decoration: none; margin-right: 0.375rem; }
  .btn-action:hover { background: var(--color-surface-subtle); }
  .btn-edit:hover { background: var(--color-info-bg); color: var(--color-info-text); border-color: var(--color-info-border); }
  .btn-delete:hover { background: var(--color-danger-bg); color: var(--color-danger); border-color: var(--color-danger-border); }
</style>
