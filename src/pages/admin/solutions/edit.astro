---
import AdminLayout from '../../../layouts/AdminLayout.astro'

export const prerender = false;

const url = new URL(Astro.request.url);
const editId = url.searchParams.get('id') || '';
---

<AdminLayout title={editId ? 'Edit Solution — Admin' : 'New Solution — Admin'} currentPath="/admin/solutions">
  <div>
    <h1 class="heading-1" style="margin-bottom: 1.5rem;">{editId ? 'Edit Solution' : 'New Solution'}</h1>
    <form id="solution-form" class="solution-form">
      <input type="hidden" id="solution-id" value={editId} />

      <div class="form-group">
        <label for="solution-title">Title</label>
        <input type="text" id="solution-title" class="input" placeholder="e.g., Data Center Power Solutions" required />
      </div>

      <div class="form-group">
        <label for="solution-industry">Industry</label>
        <input type="text" id="solution-industry" class="input" placeholder="e.g., data-centers" required />
        <p class="form-hint">URL-safe identifier used in /solutions/{'{industry}'}. Example: data-centers, healthcare, industrial</p>
      </div>

      <div class="form-group">
        <label for="solution-content">Content (HTML)</label>
        <textarea id="solution-content" class="input textarea" rows="12" placeholder="Enter HTML content for the solution page..."></textarea>
        <p class="form-hint">Supports raw HTML. This content will be rendered directly on the solution page.</p>
      </div>

      <div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
        <button type="submit" class="btn-primary" id="submit-btn">{editId ? 'Update Solution' : 'Create Solution'}</button>
        <a href="/admin/solutions" class="btn-secondary" style="text-decoration: none; display: inline-block;">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
const form = document.getElementById('solution-form') as HTMLFormElement;
const idInput = document.getElementById('solution-id') as HTMLInputElement;
const titleInput = document.getElementById('solution-title') as HTMLInputElement;
const industryInput = document.getElementById('solution-industry') as HTMLInputElement;
const contentInput = document.getElementById('solution-content') as HTMLTextAreaElement;
const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

// Load existing data if editing
if (idInput.value) {
  submitBtn.textContent = 'Loading...';
  submitBtn.disabled = true;
  fetch(`/api/solutions/${idInput.value}`)
    .then(res => {
      if (!res.ok) throw new Error('Not found');
      return res.json();
    })
    .then(data => {
      const s = data as Record<string, unknown>;
      titleInput.value = (s.title as string) || '';
      industryInput.value = (s.industry as string) || '';
      contentInput.value = (s.content as string) || '';
      submitBtn.textContent = 'Update Solution';
      submitBtn.disabled = false;
    })
    .catch(err => {
      alert('Failed to load solution: ' + err.message);
      window.location.href = '/admin/solutions';
    });
}

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  submitBtn.textContent = 'Saving...';
  submitBtn.disabled = true;

  const body = {
    title: titleInput.value.trim(),
    industry: industryInput.value.trim(),
    content: contentInput.value,
  };

  try {
    let res: Response;
    if (idInput.value) {
      res = await fetch(`/api/solutions/${idInput.value}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
    } else {
      res = await fetch('/api/solutions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
    }

    if (res.ok) {
      window.location.href = '/admin/solutions';
    } else {
      const data = await res.json().catch(() => ({})) as Record<string, string>;
      alert(data.error || 'Failed to save');
      submitBtn.textContent = idInput.value ? 'Update Solution' : 'Create Solution';
      submitBtn.disabled = false;
    }
  } catch {
    alert('Network error');
    submitBtn.textContent = idInput.value ? 'Update Solution' : 'Create Solution';
    submitBtn.disabled = false;
  }
});
</script>

<style>
  .form-group { margin-bottom: 1.25rem; }
  .form-group label { display: block; font-size: 0.8125rem; font-weight: 500; margin-bottom: 0.375rem; }
  .input { width: 100%; padding: 0.5rem 0.75rem; border-radius: var(--radius-lg); border: 1px solid var(--color-border); background: var(--color-surface); font-size: 0.875rem; color: var(--color-text); box-sizing: border-box; }
  .input:focus { outline: 2px solid var(--color-brand-600); outline-offset: -1px; }
  .textarea { font-family: 'SF Mono', 'Fira Code', 'Fira Mono', Menlo, monospace; font-size: 0.8125rem; line-height: 1.6; resize: vertical; min-height: 12rem; }
  .form-hint { font-size: 0.75rem; color: var(--color-text-tertiary); margin-top: 0.25rem; }
  .btn-secondary { display: inline-block; padding: 0.625rem 1.25rem; border-radius: var(--radius-lg); font-size: 0.875rem; font-weight: 500; background: var(--color-surface-muted); color: var(--color-text-secondary); border: 1px solid var(--color-border); cursor: pointer; }
  .btn-secondary:hover { background: var(--color-border); }
</style>
