---
import BaseLayout from '../../layouts/BaseLayout.astro'

export const prerender = true;

// Load from build-data (primary data source for static prerender)
let buildData: { settings: Record<string, string>; newsTags: Array<{ slug: string; name: string }>; news: Array<{ slug: string; title: string; summary: string | null; publishedAt: number | null; tags: Array<{ slug: string; name: string }> }> } = { settings: {}, newsTags: [], news: [] };
try {
  const { default: data } = await import('../../data/build-data.json');
  if (data) buildData = data;
} catch { /* build-data.json not generated yet */ }

const PAGE_SIZE = 12;
const currentPage = 1;

// Load tags from build-data
const allTags = buildData.newsTags || [];

// Load articles from build-data
const allNews = buildData.news || [];
const articles = allNews.slice(0, PAGE_SIZE).map(n => ({
  id: n.slug, slug: n.slug, title: n.title, summary: n.summary, publishedAt: n.publishedAt,
}));
const totalItems = allNews.length;
const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));
---

<BaseLayout title="News & Updates" buildData={buildData}>
  <section style="padding: 4rem 0;">
    <div class="container" style="max-width: 48rem;">
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem; flex-wrap: wrap;">
        <h1 class="heading-1" style="margin-bottom: 0;">News & Updates</h1>
      </div>

      {allTags.length > 0 && (
        <nav class="tag-nav" aria-label="News tags">
          <a href="/news" class:list={["tag-pill", { active: true }]}>All</a>
          {allTags.map((t) => (
            <a href={`/news/${t.slug}`} class="tag-pill">{t.name}</a>
          ))}
        </nav>
      )}

      {articles.length > 0 ? (
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {articles.map((a) => (
            <a href={`/news/${a.tags?.[0]?.slug ?? "all"}/${a.slug}`} class="card" style="text-decoration: none; display: block;">
              <h3 class="heading-3">{a.title}</h3>
              {a.summary && <p style="margin-top: 0.5rem; color: var(--color-text-secondary); font-size: 0.875rem;">{a.summary}</p>}
              <div style="margin-top: 0.5rem; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                {a.publishedAt && <span style="font-size: 0.75rem; color: var(--color-text-tertiary);">{new Date(a.publishedAt).toLocaleDateString()}</span>}
                {allNews.find(n => n.slug === a.slug)?.tags?.map(tag => (
                  <span class="tag-badge">{tag.name}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (<p style="color: var(--color-text-tertiary);">No news articles yet.</p>)}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          <span class="page-info">Page {currentPage} of {totalPages}</span>
          {totalPages > 1 && <a href="/news/page/2" class="page-btn">Next &rarr;</a>}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .tag-nav {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem;
    padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border-subtle);
  }
  .tag-pill {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 0.75rem; border-radius: var(--radius-full);
    font-size: 0.8125rem; font-weight: 500;
    border: 1px solid var(--color-border); background: var(--color-surface);
    color: var(--color-text-secondary); text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .tag-pill:hover { background: var(--color-surface-subtle); color: var(--color-text-primary); }
  .tag-pill.active {
    background: var(--color-brand-600, #2563eb); color: var(--color-text-inverse);
    border-color: var(--color-brand-600, #2563eb);
  }
  .tag-pill.active:hover { opacity: 0.9; }
  .pagination {
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--color-border-subtle);
  }
  .page-btn {
    padding: 0.375rem 0.875rem; border-radius: var(--radius-md); font-size: 0.8125rem; font-weight: 500;
    border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary);
    text-decoration: none; transition: background 0.15s;
  }
  .page-btn:hover { background: var(--color-surface-subtle); color: var(--color-text-primary); }
  .page-info { font-size: 0.8125rem; color: var(--color-text-tertiary); }
  .tag-badge {
    display: inline-block; padding: 0.125rem 0.5rem; border-radius: var(--radius-full);
    font-size: 0.6875rem; font-weight: 500; line-height: 1.4;
    background: var(--color-surface-subtle); color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
  }
</style>
