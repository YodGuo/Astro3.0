---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { newsPosts, tags, newsPostTags } from '../../../lib/db/schema'
import { eq, sql, inArray } from 'drizzle-orm'

export const prerender = true;

const MAX_PAGES = 10;
const PAGE_SIZE = 12;

// getStaticPaths: enumerate page numbers only (no tag filter)
export async function getStaticPaths() {
  const paths: Array<{ params: { page: string } }> = [];
  let maxPage = 2;
  try {
    const { default: data } = await import('../../../data/build-data.json');
    const count = data.news?.length || 0;
    maxPage = Math.min(MAX_PAGES, Math.max(2, Math.ceil(count / PAGE_SIZE)));
  } catch { /* use default */ }

  for (let p = 2; p <= maxPage; p++) {
    paths.push({ params: { page: String(p) } });
  }
  return paths;
}

const { page } = Astro.params;
if (!page) return Astro.redirect('/news');

const currentPage = Math.max(1, parseInt(page) || 1);
const offset = (currentPage - 1) * PAGE_SIZE;

// Load build-data
let buildData: { settings: Record<string, string>; newsTags: Array<{ slug: string; name: string }> } = { settings: {}, newsTags: [] };
try {
  const { default: data } = await import('../../../data/build-data.json');
  if (data?.settings) buildData = data;
} catch { /* no build-data */ }

const allTags = buildData.newsTags || [];

// Load articles (all tags, no filter)
let articles: Array<{ id: string; slug: string; title: string; summary: string | null; publishedAt: number | null; tags?: Array<{ slug: string }> }> = [];
let totalItems = 0;
let articleTags: Record<string, string[]> = {};

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    const [{ total }] = await db.select({ total: sql<number>`count(*)` }).from(newsPosts).where(eq(newsPosts.status, 'published'));
    totalItems = total;
    articles = await db
      .select({ id: newsPosts.id, slug: newsPosts.slug, title: newsPosts.title, summary: newsPosts.summary, publishedAt: newsPosts.publishedAt })
      .from(newsPosts)
      .where(eq(newsPosts.status, 'published'))
      .orderBy(sql`${newsPosts.publishedAt} desc`)
      .limit(PAGE_SIZE)
      .offset(offset) as Array<{ id: string; slug: string; title: string; summary: string | null; publishedAt: number | null }>;

    if (articles.length > 0) {
      const postIds = articles.map(a => a.id);
      const tagRows = await db.select({
        postId: newsPostTags.postId,
        tagName: tags.name,
      }).from(newsPostTags).innerJoin(tags, eq(newsPostTags.tagId, tags.id)).where(inArray(newsPostTags.postId, postIds)) as Array<{ postId: string; tagName: string }>;
      for (const row of tagRows) {
        if (!articleTags[row.postId]) articleTags[row.postId] = [];
        articleTags[row.postId].push(row.tagName);
      }
    }
  }
} catch { /* D1 not available */ }

// Fallback to build-data
if (articles.length === 0) {
  try {
    const { default: data } = await import('../../../data/build-data.json');
    const allNews = data.news || [];
    totalItems = allNews.length;
    articles = allNews.slice(offset, offset + PAGE_SIZE).map(n => ({
      id: n.slug, slug: n.slug, title: n.title, summary: n.summary, publishedAt: n.publishedAt, tags: n.tags,
    }));
  } catch { /* no build-data */ }
}

const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));
const pageTitle = 'News & Updates';
---

<BaseLayout title={pageTitle} buildData={buildData}>
  <section style="padding: 4rem 0;">
    <div class="container" style="max-width: 48rem;">
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem; flex-wrap: wrap;">
        <h1 class="heading-1" style="margin-bottom: 0;">News & Updates</h1>
      </div>

      {allTags.length > 0 && (
        <nav class="tag-nav" aria-label="News tags">
          <a href="/news" class:list={["tag-pill", { active: true }]}>All</a>
          {allTags.map((t) => (
            <a href={`/news/${t.slug}`} class="tag-pill">{t.name}</a>
          ))}
        </nav>
      )}

      {articles.length > 0 ? (
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {articles.map((a) => (
            <a href={`/news/${a.tags?.[0]?.slug ?? 'all'}/${a.slug}`} class="card" style="text-decoration: none; display: block;">
              <h3 class="heading-3">{a.title}</h3>
              {a.summary && <p style="margin-top: 0.5rem; color: var(--color-text-secondary); font-size: 0.875rem;">{a.summary}</p>}
              <div style="margin-top: 0.5rem; display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                {a.publishedAt && <span style="font-size: 0.75rem; color: var(--color-text-tertiary);">{new Date(a.publishedAt).toLocaleDateString()}</span>}
                {articleTags[a.id]?.length > 0 && articleTags[a.id].map(t => (
                  <span class="tag-badge">{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (<p style="color: var(--color-text-tertiary);">No news articles yet.</p>)}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          {currentPage > 1 && (
            currentPage === 2
              ? <a href="/news" class="page-btn">&larr; Previous</a>
              : <a href={`/news/page/${currentPage - 1}`} class="page-btn">&larr; Previous</a>
          )}
          <span class="page-info">Page {currentPage} of {totalPages}</span>
          {currentPage < totalPages && <a href={`/news/page/${currentPage + 1}`} class="page-btn">Next &rarr;</a>}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .tag-nav { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border-subtle); }
  .tag-pill { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.375rem 0.75rem; border-radius: var(--radius-full); font-size: 0.8125rem; font-weight: 500; border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); text-decoration: none; transition: background 0.15s, color 0.15s, border-color 0.15s; }
  .tag-pill:hover { background: var(--color-surface-subtle); color: var(--color-text-primary); }
  .tag-pill.active { background: var(--color-brand-600, #2563eb); color: var(--color-text-inverse); border-color: var(--color-brand-600, #2563eb); }
  .tag-pill.active:hover { opacity: 0.9; }
  .pagination { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--color-border-subtle); }
  .page-btn { padding: 0.375rem 0.875rem; border-radius: var(--radius-md); font-size: 0.8125rem; font-weight: 500; border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); text-decoration: none; transition: background 0.15s; }
  .page-btn:hover { background: var(--color-surface-subtle); color: var(--color-text-primary); }
  .page-info { font-size: 0.8125rem; color: var(--color-text-tertiary); }
  .tag-badge { display: inline-block; padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: 0.6875rem; font-weight: 500; line-height: 1.4; background: var(--color-surface-subtle); color: var(--color-text-secondary); border: 1px solid var(--color-border-subtle); }
</style>
