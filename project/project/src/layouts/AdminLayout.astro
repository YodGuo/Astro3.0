---
import '../styles/global.css'
import { getD1, batchGetSettings } from '../lib/page-visibility'
import { getEnv } from '../lib/env'

interface Props {
  title?: string;
  currentPath?: string;
}

const { title: pageTitle, currentPath = '' } = Astro.props;

const user = Astro.locals.user;

// Fetch branding settings for dynamic site name and favicon
const d1 = await getD1();
const env = await getEnv();
const settings = await batchGetSettings(d1, ['site_name', 'site_favicon_url'], env.SETTINGS_CACHE);
const siteName = settings.get('site_name') || 'YourCompany';
const siteFaviconUrl = settings.get('site_favicon_url') || '/favicon.svg';
const faviconType = siteFaviconUrl.endsWith('.svg') ? 'image/svg+xml' : siteFaviconUrl.endsWith('.ico') ? 'image/x-icon' : 'image/png';
const title = pageTitle || `Admin — ${siteName}`;

const ADMIN_NAV = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/quotes', label: 'Quotes' },
  { href: '/admin/news', label: 'News' },
  { href: '/admin/news/comments', label: 'Comments' },
  { href: '/admin/products', label: 'Products' },
  { href: '/admin/solutions', label: 'Solutions' },
  { href: '/admin/settings', label: 'Settings' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type={faviconType} href={siteFaviconUrl} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body style="margin: 0;">
    <a href="#admin-main-content" class="skip-link">Skip to main content</a>
    <!-- Mobile top bar -->
    <div class="admin-mobile-bar">
      <button class="admin-menu-btn" id="admin-menu-btn" aria-label="Toggle sidebar">
        <span class="admin-menu-bar"></span>
        <span class="admin-menu-bar"></span>
        <span class="admin-menu-bar"></span>
      </button>
      <span class="admin-mobile-title">Admin</span>
      <a href="/" class="admin-mobile-back">← Site</a>
    </div>
    <!-- Mobile overlay -->
    <div class="admin-overlay" id="admin-overlay"></div>

    <div style="display: flex; min-height: 100vh;">
      <aside class="admin-sidebar" id="admin-sidebar">
        <a href="/" class="admin-back">← Back to site</a>
        <h2 class="admin-heading">Admin Panel</h2>
        <nav class="admin-nav">
          {ADMIN_NAV.map((link) => {
            const isActive = currentPath === link.href || (link.href !== '/admin' && currentPath.startsWith(link.href));
            return (
              <a href={link.href} class:list={['admin-nav-link', { active: isActive }]}>
                {link.label}
              </a>
            );
          })}
        </nav>
        <div class="admin-user" style="margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--color-border);">
          <p style="font-size: 0.75rem; color: var(--color-text-tertiary); margin-bottom: 0.5rem;">
            {user?.name || user?.email || 'Admin'}
          </p>
          <a href="/api/auth/sign-out" style="font-size: 0.8125rem; color: var(--color-text-secondary); text-decoration: none;">Sign Out</a>
        </div>
      </aside>
      <main id="admin-main-content" class="admin-main">
        <slot />
      </main>
    </div>

    <!-- Toast Container for real-time notifications -->
    <div id="toast-container"></div>

    <script>
      // ── Mobile sidebar toggle ──
      const sidebarBtn = document.getElementById('admin-menu-btn');
      const sidebar = document.getElementById('admin-sidebar');
      const overlay = document.getElementById('admin-overlay');

      function toggleSidebar() {
        sidebar?.classList.toggle('admin-sidebar-open');
        overlay?.classList.toggle('admin-overlay-visible');
        document.body.classList.toggle('admin-body-lock');
      }

      sidebarBtn?.addEventListener('click', toggleSidebar);
      overlay?.addEventListener('click', toggleSidebar);

      // Close sidebar when clicking a nav link on mobile
      sidebar?.querySelectorAll('.admin-nav-link').forEach(link => {
        link.addEventListener('click', () => {
          sidebar?.classList.remove('admin-sidebar-open');
          overlay?.classList.remove('admin-overlay-visible');
          document.body.classList.remove('admin-body-lock');
        });
      });

      // ── Real-time Notification Toasts via SSE ──

      const EVENT_ICONS: Record<string, string> = {
        'quote.created': '🆕',
        'quote.status_changed': '📋',
        'comment.created': '💬',
        'comment.pending_review': '⚠️',
        'comment.reply_received': '↩️',
        'news.published': '📰',
        'product.published': '📦',
      };

      const EVENT_LABELS: Record<string, string> = {
        'quote.created': 'New Inquiry',
        'quote.status_changed': 'Status Update',
        'comment.created': 'New Comment',
        'comment.pending_review': 'Review Required',
        'comment.reply_received': 'Reply Received',
        'news.published': 'News Published',
        'product.published': 'Product Published',
      };

      function escHtml(str: string): string {
        const d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
      }

      function showToast(event: any) {
        const container = document.getElementById('toast-container');
        if (!container) return;

        // Check toast preferences (stored in localStorage)
        try {
          const prefs = JSON.parse(localStorage.getItem('toast_preferences') || '{}');
          if (prefs[event.eventType] === false) return; // User disabled this event type
        } catch { /* ignore: show all if prefs can't be read */ }

        const icon = EVENT_ICONS[event.eventType] || '🔔';
        const label = EVENT_LABELS[event.eventType] || event.eventType;
        const statusColor = event.status === 'sent' ? 'var(--color-brand-800)'
          : event.status === 'failed' ? 'var(--color-danger)'
          : 'var(--color-text-tertiary)';
        const statusLabel = event.status === 'sent' ? 'Sent'
          : event.status === 'failed' ? 'Failed'
          : 'Skipped';

        const toast = document.createElement('div');
        toast.className = 'toast-item';
        toast.innerHTML = `
          <div style="display:flex;align-items:flex-start;gap:0.625rem;">
            <span style="font-size:1.25rem;line-height:1;">${icon}</span>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;justify-content:space-between;align-items:center;gap:0.5rem;">
                <span style="font-weight:600;font-size:0.8125rem;">${label}</span>
                <span style="font-size:0.6875rem;padding:0.125rem 0.375rem;border-radius:var(--radius-full);font-weight:500;background:${statusColor};color:white;">${statusLabel}</span>
              </div>
              <div style="font-size:0.75rem;color:var(--color-text-tertiary);margin-top:0.125rem;">
                ${event.channelType || ''}${event.recipient ? ' → ' + escHtml(event.recipient) : ''}
                ${event.errorMessage ? '<br><span style="color:var(--color-danger);">' + escHtml(event.errorMessage) + '</span>' : ''}
              </div>
            </div>
            <button onclick="this.closest('.toast-item').remove()" style="background:none;border:none;cursor:pointer;font-size:1rem;color:var(--color-text-tertiary);padding:0;line-height:1;">×</button>
          </div>
        `;

        container.appendChild(toast);

        // Trigger enter animation
        requestAnimationFrame(() => {
          toast.classList.add('toast-visible');
        });

        // Auto-dismiss after 5 seconds
        setTimeout(() => {
          toast.classList.remove('toast-visible');
          toast.classList.add('toast-exit');
          setTimeout(() => toast.remove(), 400);
        }, 5000);
      }

      let sseConnection: EventSource | null = null;
      let pollingInterval: ReturnType<typeof setInterval> | null = null;
      let lastNotificationId: string | null = null;

      function connectSSE() {
        // Clear any existing polling
        if (pollingInterval) {
          clearInterval(pollingInterval);
          pollingInterval = null;
        }

        try {
          sseConnection = new EventSource('/api/notifications/stream');

          sseConnection.addEventListener('notification', (e: MessageEvent) => {
            try {
              const data = JSON.parse(e.data);
              showToast(data);
              lastNotificationId = data.logId;
            } catch { /* ignore parse errors */ }
          });

          sseConnection.onerror = () => {
            if (sseConnection) {
              sseConnection.close();
              sseConnection = null;
            }
            startPolling();
          };

          sseConnection.onopen = () => {
            // SSE connection established
          };

          return sseConnection;
        } catch (error) {
          console.error('[SSE] Failed to connect:', error);
          startPolling();
          return null;
        }
      }

      async function fetchLatestNotifications() {
        try {
          const params = lastNotificationId ? `?since=${encodeURIComponent(lastNotificationId)}` : '';
          const response = await fetch(`/api/notifications/latest${params}`);
          if (response.ok) {
            const notifications = await response.json();
            if (notifications && Array.isArray(notifications)) {
              for (const notification of notifications) {
                showToast(notification);
                lastNotificationId = notification.logId;
              }
            }
          }
        } catch (error) {
          console.error('[Polling] Failed to fetch notifications:', error);
        }
      }

      function startPolling() {
        if (pollingInterval) {
          clearInterval(pollingInterval);
        }

        // Fetch immediately
        fetchLatestNotifications();

        // Then start polling every 30 seconds
        pollingInterval = setInterval(fetchLatestNotifications, 30 * 1000);
      }

      // Connect when page loads
      connectSSE();

      // Listen for network status changes
      window.addEventListener('online', () => {
        if (!sseConnection) {
          connectSSE();
        }
      });
    </script>
  </body>
</html>

<style>
  .admin-sidebar {
    width: 16rem;
    flex-shrink: 0;
    border-right: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: var(--spacing-4);
    display: flex;
    flex-direction: column;
  }
  .admin-back {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1-5);
    margin-bottom: var(--spacing-6);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    color: var(--color-text-secondary);
    padding: var(--spacing-2) var(--spacing-3);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .admin-back:hover {
    background: var(--color-surface-muted);
    color: var(--color-text-primary);
    text-decoration: none;
  }
  .admin-heading {
    margin-bottom: var(--spacing-3);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-text-tertiary);
    padding-left: var(--spacing-2);
  }
  .admin-nav {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }
  .admin-nav-link {
    display: flex;
    align-items: center;
    border-radius: var(--radius-md);
    padding: var(--spacing-2-5) var(--spacing-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast), transform var(--transition-fast);
  }
  .admin-nav-link:hover {
    background: var(--color-surface-subtle);
    color: var(--color-text-primary);
    transform: translateX(2px);
  }
  .admin-nav-link.active {
    background: linear-gradient(135deg, var(--color-brand-50) 0%, var(--color-brand-100) 100%);
    color: var(--color-brand-700);
    font-weight: var(--font-weight-semibold);
    border-left: 3px solid var(--color-brand-500);
  }
  .admin-main {
    flex: 1;
    padding: var(--spacing-8);
    background: var(--color-surface-subtle);
  }

  /* ── Mobile Admin Bar ── */
  .admin-mobile-bar {
    display: none;
    position: sticky;
    top: 0;
    z-index: 60;
    align-items: center;
    gap: var(--spacing-3);
    height: 3.5rem;
    padding: 0 var(--spacing-4);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    background: rgba(255, 255, 255, 0.95);
  }
  .admin-menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.25rem;
    height: 2.25rem;
    padding: var(--spacing-2);
    background: var(--color-surface-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    flex-shrink: 0;
    transition: background var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }
  .admin-menu-btn:hover {
    background: var(--color-surface-muted);
    border-color: var(--color-gray-300);
  }
  .admin-menu-btn:active {
    transform: scale(0.95);
  }
  .admin-menu-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text-secondary);
    border-radius: 1px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }
  .admin-mobile-title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    flex: 1;
  }
  .admin-mobile-back {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    white-space: nowrap;
    padding: var(--spacing-2) var(--spacing-3);
    border-radius: var(--radius-md);
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .admin-mobile-back:hover {
    background: var(--color-surface-subtle);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  /* ── Mobile Overlay ── */
  .admin-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 70;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  .admin-overlay-visible {
    display: block;
    animation: fadeIn 0.2s ease-out;
  }
  .admin-body-lock {
    overflow: hidden;
  }

  /* ── Mobile Responsive ── */
  @media (max-width: 768px) {
    .admin-mobile-bar {
      display: flex;
    }

    .admin-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 80;
      width: 18rem;
      transform: translateX(-100%);
      transition: transform var(--transition-normal);
      padding-top: var(--spacing-4);
      box-shadow: var(--shadow-xl);
    }
    .admin-sidebar.admin-sidebar-open {
      transform: translateX(0);
    }

    .admin-main {
      padding: var(--spacing-4);
    }

    #toast-container {
      max-width: calc(100vw - 2rem);
      right: var(--spacing-4);
      left: var(--spacing-4);
    }
  }

  /* ── Toast Notifications ── */
  #toast-container {
    position: fixed;
    top: var(--spacing-4);
    right: var(--spacing-4);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    max-width: 400px;
    pointer-events: none;
  }
  .toast-item {
    pointer-events: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--spacing-4);
    box-shadow: var(--shadow-xl);
    opacity: 0;
    transform: translateY(-10px) scale(0.95);
    transition: opacity var(--transition-normal), transform var(--transition-normal);
  }
  .toast-item.toast-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .toast-item.toast-exit {
    opacity: 0;
    transform: translateY(-10px) scale(0.95);
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
