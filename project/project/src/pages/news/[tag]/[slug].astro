---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { sanitizeHtml } from '../../../lib/sanitize'
import { optimizeImage, IMAGE_PRESETS } from '../../../lib/image-optimize'

export const prerender = true;

// getStaticPaths runs at module scope — use dynamic import with fallback
export async function getStaticPaths() {
  let buildDataNews: Array<{ slug: string; tags?: Array<{ slug: string }> }> = [];
  try {
    const { default: data } = await import('../../../data/build-data.json');
    buildDataNews = data.news || [];
  } catch { /* build-data.json not generated yet — no static pages */ }
  return buildDataNews.map((n) => ({ params: { tag: n.tags?.[0]?.slug ?? 'all', slug: n.slug } }));
}

const { tag, slug } = Astro.params;
if (!tag || !slug) return Astro.redirect('/404');

// Load from build-data (primary data source for static prerender)
let article: { id: string; title: string; summary: string | null; content: string | null; publishedAt: number | null; status?: string } | null = null;
let articleTagList: Array<{ id: string; name: string; slug: string }> = [];
let siteName = 'YourCompany';
let tagName = tag;

try {
  const { default: data } = await import('../../../data/build-data.json');
  const found = (data.news || []).find((n: any) => n.slug === slug);
  if (found) {
    article = {
      id: found.slug,
      title: found.title,
      summary: found.summary || null,
      content: found.content || null,
      publishedAt: found.publishedAt || null,
      status: found.status || 'published',
    };
    articleTagList = found.tags || [];
    if (data.settings?.site_name) siteName = data.settings.site_name;
  }
  const tagObj = (data.newsTags || []).find((t: any) => t.slug === tag);
  tagName = tagObj?.name || tag;
} catch { /* no build-data */ }

/** Render TipTap JSON AST to HTML string */
function renderTiptapJson(json: string): string {
  try {
    const doc = JSON.parse(json);
    if (!doc || doc.type !== 'doc' || !Array.isArray(doc.content)) return '';
    return doc.content.map(renderNode).join('\n');
  } catch {
    return json; // fallback: return raw content if not valid JSON
  }
}

function renderNode(node: any): string {
  if (!node || !node.type) return '';
  const children = node.content ? node.content.map(renderNode).join('') : (node.text || '');
  switch (node.type) {
    case 'paragraph': return `<p>${children}</p>`;
    case 'heading': return `<h${node.attrs?.level || 2}>${children}</h${node.attrs?.level || 2}>`;
    case 'bulletList': return `<ul>${children}</ul>`;
    case 'orderedList': return `<ol>${children}</ol>`;
    case 'listItem': return `<li>${children}</li>`;
    case 'blockquote': return `<blockquote>${children}</blockquote>`;
    case 'codeBlock': return `<pre><code>${escapeHtml(node.content?.map((c: any) => c.text || '').join('\n') || '')}</code></pre>`;
    case 'hardBreak': return '<br>';
    case 'horizontalRule': return '<hr>';
    case 'image': {
      const rawSrc = node.attrs?.src || '';
      const optimizedSrc = optimizeImage(rawSrc, IMAGE_PRESETS.article);
      return `<img src="${escapeHtml(optimizedSrc)}" alt="${escapeHtml(node.attrs?.alt || '')}" loading="lazy" />`;
    }
    case 'link': return `<a href="${escapeHtml(sanitizeHref(node.attrs?.href || ''))}">${children}</a>`;
    default:
      if (node.text) return applyMarks(node.text, node.marks);
      return children;
  }
}

function applyMarks(text: string, marks?: any[]): string {
  if (!marks || !marks.length) return escapeHtml(text);
  let result = escapeHtml(text);
  for (const mark of marks) {
    switch (mark.type) {
      case 'bold': result = `<strong>${result}</strong>`; break;
      case 'italic': result = `<em>${result}</em>`; break;
      case 'strike': result = `<s>${result}</s>`; break;
      case 'code': result = `<code>${result}</code>`; break;
      case 'link': result = `<a href="${escapeHtml(sanitizeHref(mark.attrs?.href || ''))}">${result}</a>`; break;
    }
  }
  return result;
}

/** Sanitize URL to prevent javascript: protocol XSS */
function sanitizeHref(href: string): string {
  const trimmed = href.trim();
  if (/^javascript\s*:/i.test(trimmed)) return '#';
  if (/^data\s*:/i.test(trimmed)) return '#';
  if (/^vbscript\s*:/i.test(trimmed)) return '#';
  return href;
}

function escapeHtml(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

const articleHtml = article?.content ? sanitizeHtml(renderTiptapJson(article.content)) : '';
const isDraft = article?.status === 'draft';
---
<BaseLayout
  title={article ? article.title : 'News'}
  description={article?.summary || undefined}
  ogType="article"
  noIndex={isDraft}
  articleMeta={article ? {
    publishedTime: article.publishedAt ? new Date(article.publishedAt).toISOString() : undefined,
    author: siteName,
    tags: articleTagList.map(t => t.name),
  } : undefined}
>
  {article && (
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": article.title,
        "description": article.summary || "",
        "datePublished": article.publishedAt ? new Date(article.publishedAt).toISOString() : undefined,
        "url": Astro.url.href,
        "author": { "@type": "Organization", "name": siteName },
        "publisher": { "@type": "Organization", "name": siteName }
      },
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL("/", Astro.url).href },
          { "@type": "ListItem", "position": 2, "name": "News", "item": new URL("/news", Astro.url).href },
          { "@type": "ListItem", "position": 3, "name": tagName, "item": new URL(`/news/${tag}`, Astro.url).href },
          { "@type": "ListItem", "position": 4, "name": article.title, "item": Astro.url.href }
        ]
      }
    ])} />
  )}
  <section style="padding: 4rem 0;">
    <div class="container" style="max-width: 48rem;">
      {article ? (
        <>
          <h1 class="heading-1" style="margin-bottom: 1rem;">{article.title}</h1>
          <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem;">
            {article.publishedAt && <span style="font-size: 0.875rem; color: var(--color-text-tertiary);">{new Date(article.publishedAt).toLocaleDateString()}</span>}
            {articleTagList.length > 0 && articleTagList.map(tag => (
              <a href={`/news/${tag.slug}`} class="tag-badge" style="text-decoration: none;">{tag.name}</a>
            ))}
          </div>
          {article.summary && <p style="color: var(--color-text-secondary); font-size: 1.0625rem; margin-bottom: 2rem; line-height: 1.8;">{article.summary}</p>}
          {articleHtml && <div class="prose" style="color: var(--color-text-secondary); line-height: 1.8;" set:html={articleHtml} />}

          <!-- Comments Section -->
          <div id="comments-section" style="margin-top: 3rem; border-top: 1px solid var(--color-border); padding-top: 2rem;">
            <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 1.5rem;">Comments</h2>

            <!-- Comment Form -->
            <form id="comment-form" style="display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; padding: 1.25rem; background: var(--color-surface-subtle); border-radius: var(--radius-xl); border: 1px solid var(--color-border);">
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                  <label for="comment-name" style="font-size: 0.8125rem; font-weight: 500;">Name *</label>
                  <input id="comment-name" type="text" name="authorName" placeholder="Your name *" required style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                  <label for="comment-email" style="font-size: 0.8125rem; font-weight: 500;">Email *</label>
                  <input id="comment-email" type="email" name="authorEmail" placeholder="Your email *" required style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
                </div>
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <label for="comment-content" style="font-size: 0.8125rem; font-weight: 500;">Comment *</label>
                <textarea id="comment-content" name="content" placeholder="Write a comment..." required rows={3} style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; resize: vertical; background: var(--color-surface);"></textarea>
              </div>
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <p style="font-size: 0.75rem; color: var(--color-text-tertiary); margin: 0;">Your comment will be visible after approval.</p>
                <button type="submit" id="comment-submit-btn" style="padding: 0.5rem 1rem; border-radius: var(--radius-md); font-size: 0.875rem; font-weight: 500; background: var(--color-brand-600); color: var(--color-text-inverse); border: none; cursor: pointer;">Submit Comment</button>
              </div>
            </form>

            <!-- Comments List -->
            <div id="comments-list">
              <p style="color: var(--color-text-tertiary); font-size: 0.875rem;">Loading comments...</p>
            </div>
          </div>
        </>
      ) : (<p style="color: var(--color-text-tertiary);">Article not found.</p>)}
    </div>
  </section>
</BaseLayout>

<script define:vars={{ postId: article?.id || '' }}>
(function() {
  if (!postId) return;

  const form = document.getElementById('comment-form');
  const listEl = document.getElementById('comments-list');
  const submitBtn = document.getElementById('comment-submit-btn');

  function escHtml(str) {
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function formatDate(ts) {
    if (!ts) return '';
    const d = new Date(ts);
    return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
  }

  // Render a single comment (with nested replies)
  function renderComment(c, replies) {
    const childReplies = replies.filter(r => r.parentId === c.id);
    let html = `
      <div class="comment-item" id="comment-${c.id}">
        <div class="comment-header">
          <strong style="font-size: 0.875rem;">${escHtml(c.authorName)}</strong>
          <span style="font-size: 0.75rem; color: var(--color-text-tertiary);">${formatDate(c.createdAt)}</span>
        </div>
        <p class="comment-body">${escHtml(c.content)}</p>
        <button class="reply-toggle" data-parent-id="${c.id}">Reply</button>
        <div class="reply-form" data-parent-id="${c.id}" style="display:none;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem;">
            <input type="text" class="reply-name" placeholder="Your name *" required style="padding: 0.375rem 0.625rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.8125rem; background: var(--color-surface);" />
            <input type="email" class="reply-email" placeholder="Your email *" required style="padding: 0.375rem 0.625rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.8125rem; background: var(--color-surface);" />
          </div>
          <textarea class="reply-content" placeholder="Write a reply..." required rows={2} style="padding: 0.375rem 0.625rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.8125rem; resize: vertical; width: 100%; background: var(--color-surface);"></textarea>
          <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
            <button class="reply-submit" data-parent-id="${c.id}" style="padding: 0.375rem 0.75rem; border-radius: var(--radius-md); font-size: 0.8125rem; font-weight: 500; background: var(--color-brand-600); color: var(--color-text-inverse); border: none; cursor: pointer;">Reply</button>
            <button class="reply-cancel" data-parent-id="${c.id}" style="padding: 0.375rem 0.75rem; border-radius: var(--radius-md); font-size: 0.8125rem; border: 1px solid var(--color-border); background: var(--color-surface); cursor: pointer;">Cancel</button>
          </div>
        </div>
    `;
    if (childReplies.length > 0) {
      html += '<div class="comment-replies">';
      childReplies.forEach(r => { html += renderComment(r, []); });
      html += '</div>';
    }
    html += '</div>';
    return html;
  }

  // Load and render comments
  async function loadComments() {
    try {
      const res = await fetch(`/api/comments?postId=${postId}`);
      if (!res.ok) { listEl.innerHTML = '<p style="color: var(--color-text-tertiary); font-size: 0.875rem;">Failed to load comments.</p>'; return; }
      const json = await res.json();
      // Support both old array format and new paginated format
      const all = Array.isArray(json) ? json : (json.data || []);
      // Only show approved comments
      const approved = all.filter(c => c.status === 'approved');
      // Separate root comments and replies
      const roots = approved.filter(c => !c.parentId);
      if (roots.length === 0) {
        listEl.innerHTML = '<p style="color: var(--color-text-tertiary); font-size: 0.875rem;">No comments yet. Be the first to comment!</p>';
        return;
      }
      listEl.innerHTML = roots.map(c => renderComment(c, approved)).join('');
    } catch {
      listEl.innerHTML = '<p style="color: var(--color-text-tertiary); font-size: 0.875rem;">Failed to load comments.</p>';
    }
  }

  loadComments();

  // Submit root comment
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const fd = new FormData(form);
    try {
      const res = await fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          postId,
          authorName: fd.get('authorName'),
          authorEmail: fd.get('authorEmail'),
          content: fd.get('content'),
        }),
      });
      if (res.ok) {
        form.reset();
        // Show success message
        const msg = document.createElement('p');
        msg.style.cssText = 'color: var(--color-success-text); font-size: 0.875rem; margin: 0;';
        msg.textContent = 'Comment submitted! It will appear after approval.';
        form.querySelector('button')?.after(msg);
        setTimeout(() => msg.remove(), 4000);
      } else {
        const data = await res.json().catch(() => ({}));
        alert(data.error || 'Failed to submit comment');
      }
    } catch {
      alert('Network error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Comment';
    }
  });

  // Reply toggle / submit / cancel (event delegation)
  listEl?.addEventListener('click', async (e) => {
    const replyToggle = e.target.closest('.reply-toggle');
    const replySubmit = e.target.closest('.reply-submit');
    const replyCancel = e.target.closest('.reply-cancel');

    if (replyToggle) {
      const parentId = replyToggle.dataset.parentId;
      const replyForm = listEl.querySelector(`.reply-form[data-parent-id="${parentId}"]`);
      if (replyForm) replyForm.style.display = replyForm.style.display === 'none' ? 'block' : 'none';
    }

    if (replyCancel) {
      const parentId = replyCancel.dataset.parentId;
      const replyForm = listEl.querySelector(`.reply-form[data-parent-id="${parentId}"]`);
      if (replyForm) replyForm.style.display = 'none';
    }

    if (replySubmit) {
      const parentId = replySubmit.dataset.parentId;
      const replyForm = listEl.querySelector(`.reply-form[data-parent-id="${parentId}"]`);
      if (!replyForm) return;

      const nameEl = replyForm.querySelector('.reply-name');
      const emailEl = replyForm.querySelector('.reply-email');
      const contentEl = replyForm.querySelector('.reply-content');
      const name = nameEl && nameEl.value ? nameEl.value : '';
      const email = emailEl && emailEl.value ? emailEl.value : '';
      const content = contentEl && contentEl.value ? contentEl.value : '';

      if (!name || !email || !content) { alert('All fields are required'); return; }

      replySubmit.disabled = true;
      replySubmit.textContent = 'Submitting...';

      try {
        const res = await fetch('/api/comments', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ postId, parentId, authorName: name, authorEmail: email, content }),
        });
        if (res.ok) {
          replyForm.style.display = 'none';
          replyForm.querySelectorAll('input, textarea').forEach(el => { el.value = ''; });
          const msg = document.createElement('p');
          msg.style.cssText = 'color: var(--color-success-text); font-size: 0.8125rem; margin: 0.25rem 0 0 0;';
          msg.textContent = 'Reply submitted! It will appear after approval.';
          replySubmit.after(msg);
          setTimeout(() => msg.remove(), 4000);
        } else {
          const data = await res.json().catch(() => ({}));
          alert(data.error || 'Failed to submit reply');
        }
      } catch {
        alert('Network error');
      } finally {
        replySubmit.disabled = false;
        replySubmit.textContent = 'Reply';
      }
    }
  });
})();
</script>

<style>
  .tag-badge {
    display: inline-block; padding: 0.125rem 0.5rem; border-radius: var(--radius-full);
    font-size: 0.6875rem; font-weight: 500; line-height: 1.4;
    background: var(--color-surface-subtle); color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle); transition: background 0.15s, color 0.15s;
  }
  .tag-badge:hover { background: var(--color-border-subtle); color: var(--color-text-primary); }
  .comment-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border-subtle);
  }
  .comment-item:last-child { border-bottom: none; }
  .comment-header {
    display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.375rem;
  }
  .comment-body {
    margin: 0; font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6;
  }
  .reply-toggle {
    margin-top: 0.5rem; padding: 0.125rem 0.5rem; border-radius: var(--radius-sm); font-size: 0.75rem;
    border: 1px solid var(--color-border); background: var(--color-surface); cursor: pointer;
    color: var(--color-text-tertiary);
  }
  .reply-toggle:hover { color: var(--color-text-secondary); background: var(--color-surface-subtle); }
  .comment-replies {
    margin-left: 1.5rem; padding-left: 1rem; border-left: 2px solid var(--color-border-subtle);
  }
</style>
