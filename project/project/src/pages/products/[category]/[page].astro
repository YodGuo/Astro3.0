---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { products, productCategories } from '../../../lib/db/schema'
import { eq, sql } from 'drizzle-orm'

export const prerender = true;

const MAX_PAGES = 10;
const PAGE_SIZE = 12;

// getStaticPaths: enumerate category × page combinations
export async function getStaticPaths() {
  let categories: Array<{ slug: string }> = [];
  try {
    const { default: data } = await import('../../../data/build-data.json');
    categories = data.productCategories || [];
  } catch { /* no build-data */ }

  const slugs = ['all', ...categories.map(c => c.slug)];
  const paths: Array<{ params: { category: string; page: string } }> = [];

  for (const category of slugs) {
    // When no build-data, generate page 2 only as a minimal placeholder
    // When build-data exists, calculate actual page count
    let maxPage = 2;
    try {
      const { default: data } = await import('../../../data/build-data.json');
      const count = (data.products?.length || 0);
      maxPage = Math.min(MAX_PAGES, Math.max(2, Math.ceil(count / PAGE_SIZE)));
    } catch { /* use default */ }

    for (let p = 2; p <= maxPage; p++) {
      paths.push({ params: { category, page: String(p) } });
    }
  }
  return paths;
}

const { category, page } = Astro.params;
if (!category || !page) return Astro.redirect('/products');

const currentPage = Math.max(1, parseInt(page) || 1);
const offset = (currentPage - 1) * PAGE_SIZE;

// Load build-data
let buildData: { settings: Record<string, string>; productCategories: Array<{ slug: string; name: string }> } = { settings: {}, productCategories: [] };
try {
  const { default: data } = await import('../../../data/build-data.json');
  if (data?.settings) buildData = data;
} catch { /* no build-data */ }

const categories = buildData.productCategories || [];
const isAll = category === 'all';
const categoryObj = categories.find(c => c.slug === category);
const filterCategoryName = isAll ? null : (categoryObj?.name || null);

// Load products
let productList: Array<{ slug: string; name: string; summary: string | null }> = [];
let totalItems = 0;

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    let filterCategoryId: string | null = null;
    if (!isAll && category) {
      const catRows = await db.select({ id: productCategories.id }).from(productCategories).where(eq(productCategories.slug, category)).limit(1);
      if (catRows.length > 0) filterCategoryId = catRows[0].id as string;
    }

    const whereClause = filterCategoryId
      ? sql`WHERE category_id = ${filterCategoryId} AND published = 1`
      : sql`WHERE published = 1`;

    const rows = await db.execute(sql`
      SELECT slug, name, summary, COUNT(*) OVER() as total_count
      FROM products ${whereClause}
      ORDER BY created_at DESC
      LIMIT ${PAGE_SIZE} OFFSET ${offset}
    `);
    totalItems = rows.rows[0]?.total_count ?? 0;
    productList = rows.rows as Array<{ slug: string; name: string; summary: string | null }>;
  }
} catch { /* D1 not available */ }

// Fallback to build-data
if (productList.length === 0) {
  try {
    const { default: data } = await import('../../../data/build-data.json');
    const allProducts = data.products || [];
    totalItems = allProducts.length;
    productList = allProducts.slice(offset, offset + PAGE_SIZE);
  } catch { /* no build-data */ }
}

const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));
const pageTitle = filterCategoryName ? `Products: ${filterCategoryName}` : 'Products';
---

<BaseLayout title={pageTitle} buildData={buildData}>
  <section style="padding: 4rem 0;">
    <div class="container">
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
        <h1 class="heading-1" style="margin-bottom: 0;">Products</h1>
        {filterCategoryName && (
          <a href="/products" class="filter-badge" title="Clear filter">
            {filterCategoryName} ✕
          </a>
        )}
      </div>

      {categories.length > 0 && (
        <nav class="category-nav" aria-label="Product categories">
          <a href="/products" class:list={["cat-pill", { active: isAll }]}>All</a>
          {categories.map((c) => (
            <a href={`/products/${c.slug}`} class:list={["cat-pill", { active: category === c.slug }]}>
              {c.name}
            </a>
          ))}
        </nav>
      )}

      {productList.length > 0 ? (
        <div style="display: grid; gap: 1.5rem; grid-template-columns: repeat(3, 1fr);">
          {productList.map((p) => (
            <a href={`/products/${p.brandSlug ?? "other"}/${p.slug}`} class="card" style="text-decoration: none; display: block;">
              <h3 class="heading-3">{p.name}</h3>
              <p style="margin-top: 0.5rem; color: var(--color-text-secondary); font-size: 0.875rem;">{p.summary}</p>
            </a>
          ))}
        </div>
      ) : (<p style="color: var(--color-text-tertiary);">{filterCategoryName ? `No products in "${filterCategoryName}".` : 'No products available yet.'}</p>)}

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          {currentPage > 1 && (
            currentPage === 2
              ? <a href={`/products/${category}`} class="page-btn">&larr; Previous</a>
              : <a href={`/products/${category}/${currentPage - 1}`} class="page-btn">&larr; Previous</a>
          )}
          <span class="page-info">Page {currentPage} of {totalPages}</span>
          {currentPage < totalPages && <a href={`/products/${category}/${currentPage + 1}`} class="page-btn">Next &rarr;</a>}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .category-nav {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem;
    padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-border-subtle);
  }
  .cat-pill {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 0.75rem; border-radius: var(--radius-full);
    font-size: 0.8125rem; font-weight: 500;
    border: 1px solid var(--color-border); background: var(--color-surface);
    color: var(--color-text-secondary); text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .cat-pill:hover { background: var(--color-surface-subtle); color: var(--color-text-primary); }
  .cat-pill.active {
    background: var(--color-brand-600, #2563eb); color: var(--color-text-inverse);
    border-color: var(--color-brand-600, #2563eb);
  }
  .cat-pill.active:hover { opacity: 0.9; }
  .filter-badge {
    display: inline-block; padding: 0.25rem 0.75rem; border-radius: var(--radius-full);
    font-size: 0.8125rem; font-weight: 500; line-height: 1.4;
    background: var(--color-brand-600, #2563eb); color: var(--color-text-inverse);
    text-decoration: none; transition: opacity 0.15s;
  }
  .filter-badge:hover { opacity: 0.85; }
  .pagination {
    display: flex; align-items: center; justify-content: center; gap: 1rem;
    margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--color-border-subtle);
  }
  .page-btn {
    padding: 0.375rem 0.875rem; border-radius: var(--radius-md); font-size: 0.8125rem; font-weight: 500;
    border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary);
    text-decoration: none; transition: background 0.15s;
  }
  .page-btn:hover { background: var(--color-surface-subtle); color: var(--color-text-primary); }
  .page-info { font-size: 0.8125rem; color: var(--color-text-tertiary); }
</style>
