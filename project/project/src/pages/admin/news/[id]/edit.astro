---
import AdminLayout from '../../../../layouts/AdminLayout.astro'
import LazyNewsForm from '../../../../components/admin/LazyNewsForm.tsx'

export const prerender = false;

const { id } = Astro.params;
---

<AdminLayout title="Edit Article — Admin" currentPath="/admin/news">
  <div>
    <h1 class="heading-1" style="margin-bottom: 1.5rem;">Edit Article</h1>
    <LazyNewsForm client:only="react" mode="edit" articleId={id} />
  </div>
</AdminLayout>
