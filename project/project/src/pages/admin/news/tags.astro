---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { tags } from '../../../lib/db/schema'
import { sql } from 'drizzle-orm'

export const prerender = false;

let tagsList: Array<{ id: string; name: string; slug: string; postCount: number }> = [];

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    tagsList = await db
      .select({
        id: tags.id,
        name: tags.name,
        slug: tags.slug,
        postCount: sql<number>`(SELECT COUNT(*) FROM news_post_tags WHERE tag_id = ${tags.id})`.as("post_count"),
      })
      .from(tags)
      .orderBy(sql`post_count desc`);
  }
} catch { /* D1 not available */ }
---

<AdminLayout title="Tags — Admin" currentPath="/admin/news/tags">
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
      <h1 class="heading-1" style="margin-bottom: 0;">Tags</h1>
      <button id="btn-create" class="btn-primary">+ New Tag</button>
    </div>

    <!-- Create / Edit Modal -->
    <div id="tag-modal" class="modal-overlay" style="display: none;">
      <div class="modal-card">
        <h2 id="modal-title" style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Create Tag</h2>
        <form id="tag-form" style="display: flex; flex-direction: column; gap: 0.75rem;">
          <input type="hidden" id="tag-id" name="id" value="" />
          <label style="font-size: 0.8125rem; font-weight: 500; color: var(--color-text-secondary);">Name</label>
          <input type="text" id="tag-name" name="name" required maxlength="50" placeholder="e.g. Data Center" style="padding: 0.5rem 0.75rem; border-radius: var(--radius-md); border: 1px solid var(--color-border); font-size: 0.875rem; background: var(--color-surface);" />
          <p id="modal-error" style="display: none; color: var(--color-danger-text); font-size: 0.8125rem; margin: 0;"></p>
          <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 0.5rem;">
            <button type="button" id="btn-cancel" class="btn-action">Cancel</button>
            <button type="submit" class="btn-primary" style="padding: 0.375rem 1rem; font-size: 0.8125rem;">Save</button>
          </div>
        </form>
      </div>
    </div>

    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Name</th><th>Slug</th><th>Posts</th><th>Actions</th></tr></thead>
        <tbody id="tags-tbody">
          {tagsList.length > 0 ? tagsList.map((t) => (
            <tr data-id={t.id} data-name={t.name}>
              <td style="font-weight: 500;">{t.name}</td>
              <td style="color: var(--color-text-tertiary); font-size: 0.8125rem;">{t.slug}</td>
              <td><span class="badge-gray">{t.postCount}</span></td>
              <td style="white-space: nowrap;">
                <button class="btn-action btn-edit" data-action="edit">Edit</button>
                <button class="btn-action btn-delete" data-action="delete">Delete</button>
              </td>
            </tr>
          )) : (<tr><td colspan="4" class="empty-cell">No tags yet.</td></tr>)}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<script>
(function() {
  const modal = document.getElementById('tag-modal') as HTMLDivElement;
  const form = document.getElementById('tag-form') as HTMLFormElement;
  const titleEl = document.getElementById('modal-title') as HTMLHeadingElement;
  const idInput = document.getElementById('tag-id') as HTMLInputElement;
  const nameInput = document.getElementById('tag-name') as HTMLInputElement;
  const errorEl = document.getElementById('modal-error') as HTMLParagraphElement;
  const tbody = document.getElementById('tags-tbody') as HTMLTableSectionElement;

  function openModal(mode: 'create' | 'edit', id?: string, name?: string) {
    titleEl.textContent = mode === 'create' ? 'Create Tag' : 'Edit Tag';
    idInput.value = id || '';
    nameInput.value = name || '';
    errorEl.style.display = 'none';
    modal.style.display = 'flex';
    nameInput.focus();
  }

  function closeModal() { modal.style.display = 'none'; }

  document.getElementById('btn-create')?.addEventListener('click', () => openModal('create'));
  document.getElementById('btn-cancel')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.style.display = 'none';
    const name = nameInput.value.trim();
    if (!name) return;

    const id = idInput.value;
    const isEdit = !!id;
    const url = isEdit ? `/api/tags/${id}` : '/api/tags';
    const method = isEdit ? 'PUT' : 'POST';

    try {
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name }),
      });
      if (res.ok) {
        // Reload page to reflect changes
        window.location.reload();
      } else {
        const data = await res.json().catch(() => ({})) as Record<string, string>;
        errorEl.textContent = data.error || 'Failed to save tag';
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.textContent = 'Network error';
      errorEl.style.display = 'block';
    }
  });

  tbody?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-action]') as HTMLButtonElement | null;
    if (!btn) return;

    const action = btn.dataset.action;
    const row = btn.closest('tr') as HTMLTableRowElement | null;
    if (!row) return;

    const id = row.dataset.id;
    const name = row.dataset.name || '';
    if (!id) return;

    if (action === 'edit') {
      openModal('edit', id, name);
      return;
    }

    if (action === 'delete') {
      const postCount = parseInt(row.querySelector('.badge-gray')?.textContent || '0');
      if (postCount > 0) {
        if (!confirm(`This tag is used by ${postCount} post(s). Deleting it will remove the association. Continue?`)) return;
      } else {
        if (!confirm('Delete this tag?')) return;
      }

      btn.disabled = true;
      try {
        const res = await fetch(`/api/tags/${id}`, { method: 'DELETE' });
        if (res.ok) {
          row.remove();
        } else {
          const data = await res.json().catch(() => ({})) as Record<string, string>;
          alert(data.error || 'Failed to delete tag');
          btn.disabled = false;
        }
      } catch {
        alert('Network error');
        btn.disabled = false;
      }
    }
  });
})();
</script>

<style>
  .btn-primary {
    padding: 0.5rem 1rem; border-radius: var(--radius-lg); font-size: 0.875rem; font-weight: 500;
    background: var(--color-brand-600, #2563eb); color: var(--color-text-inverse); border: none; cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.9; }

  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex;
    align-items: center; justify-content: center; z-index: 100;
  }
  .modal-card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius-xl); padding: 1.5rem; width: 100%; max-width: 24rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  .admin-table-wrap { overflow: hidden; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
  .admin-table { width: 100%; font-size: 0.875rem; border-collapse: collapse; }
  .admin-table thead tr { border-bottom: 1px solid var(--color-border); background: var(--color-surface-subtle); }
  .admin-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 500; }
  .admin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .empty-cell { padding: 2rem 1rem !important; text-align: center; color: var(--color-text-tertiary); }

  .btn-action {
    padding: 0.25rem 0.625rem; border-radius: var(--radius-md); font-size: 0.75rem; font-weight: 500;
    border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary);
    cursor: pointer; margin-right: 0.25rem; transition: background 0.15s, color 0.15s;
  }
  .btn-action:hover:not(:disabled) { background: var(--color-surface-subtle); }
  .btn-action:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-edit:hover:not(:disabled) { background: var(--color-info-bg); color: var(--color-info-text); border-color: var(--color-info-border); }
  .btn-delete:hover:not(:disabled) { background: var(--color-danger-bg); color: var(--color-danger-text); border-color: var(--color-danger-border); }

  .badge-gray {
    display: inline-block; padding: 0.125rem 0.5rem; border-radius: var(--radius-full);
    font-size: 0.75rem; font-weight: 500; background: var(--color-surface-subtle);
    color: var(--color-text-secondary); border: 1px solid var(--color-border-subtle);
  }
</style>
