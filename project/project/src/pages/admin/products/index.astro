---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { products } from '../../../lib/db/schema'
import { sql } from 'drizzle-orm'

export const prerender = false;

let productList: Array<{ id: string; name: string; slug: string; published: boolean | null; createdAt: number | null }> = [];

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    productList = await db.select({ id: products.id, name: products.name, slug: products.slug, published: products.published, createdAt: products.createdAt }).from(products).orderBy(sql`${products.createdAt} desc`) as unknown as Array<{ id: string; name: string; slug: string; published: boolean | null; createdAt: number | null }>;
  }
} catch { /* D1 not available */ }
---

<AdminLayout title="Products — Admin" currentPath="/admin/products">
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
      <h1 class="heading-1">Products</h1>
      <a href="/admin/products/new" class="btn-primary" style="text-decoration: none; font-size: 0.875rem; padding: 0.5rem 1rem;">+ New Product</a>
    </div>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Name</th><th>Status</th><th>Date</th></tr></thead>
        <tbody>
          {productList.length > 0 ? productList.map((p) => (
            <tr><td><a href={`/admin/products/${p.id}/edit`} style="color: var(--color-brand-600); text-decoration: none;">{p.name}</a></td><td><span class="badge-gray">{p.published ? 'Published' : 'Draft'}</span></td><td>{p.createdAt ? new Date(p.createdAt).toLocaleDateString() : '—'}</td></tr>
          )) : (<tr><td colspan="3" class="empty-cell">No products yet.</td></tr>)}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>

<style>
  .admin-table-wrap { overflow: hidden; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
  .admin-table { width: 100%; font-size: 0.875rem; border-collapse: collapse; }
  .admin-table thead tr { border-bottom: 1px solid var(--color-border); background: var(--color-surface-subtle); }
  .admin-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 500; }
  .admin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .empty-cell { padding: 2rem 1rem !important; text-align: center; color: var(--color-text-tertiary); }
</style>
