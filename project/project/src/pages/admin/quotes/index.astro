---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDBFromEnv } from '../../../lib/db'
import { getEnv } from '../../../lib/env'
import { quoteRequests } from '../../../lib/db/schema'
import { sql } from 'drizzle-orm'

export const prerender = false;

let quotes: Array<{ id: string; name: string | null; company: string | null; product: string | null; status: string | null; createdAt: number | null }> = [];

try {
  const env = await getEnv();
  const db = getDBFromEnv(env);
  if (db) {
    quotes = await db.select({ id: quoteRequests.id, name: quoteRequests.name, company: quoteRequests.company, product: quoteRequests.product, status: quoteRequests.status, createdAt: quoteRequests.createdAt }).from(quoteRequests).orderBy(sql`${quoteRequests.createdAt} desc`) as unknown as Array<{ id: string; name: string | null; company: string | null; product: string | null; status: string | null; createdAt: number | null }>;
  }
} catch { /* D1 not available */ }
---

<AdminLayout title="Quotes — Admin" currentPath="/admin/quotes">
  <div>
    <h1 class="heading-1" style="margin-bottom: 1.5rem;">Quote Requests</h1>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead><tr><th>Name</th><th>Company</th><th>Product</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody id="quotes-tbody">
          {quotes.length > 0 ? quotes.map((q) => (
            <tr data-id={q.id}>
              <td>{q.name || '—'}</td>
              <td>{q.company || '—'}</td>
              <td>{q.product || '—'}</td>
              <td>
                <select class="status-select" data-role="status-select" disabled>
                  <option value="new" selected={(q.status || 'new') === 'new'}>New</option>
                  <option value="contacted" selected={q.status === 'contacted'}>Contacted</option>
                  <option value="quoted" selected={q.status === 'quoted'}>Quoted</option>
                  <option value="closed" selected={q.status === 'closed'}>Closed</option>
                </select>
              </td>
              <td>{q.createdAt ? new Date(q.createdAt).toLocaleDateString() : '—'}</td>
              <td style="white-space: nowrap;">
                <button class="btn-action btn-view" data-action="view">View</button>
              </td>
            </tr>
          )) : (<tr><td colspan="6" class="empty-cell">No quote requests yet.</td></tr>)}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Detail Modal -->
  <div id="quote-modal" class="modal-overlay" style="display:none;">
    <div class="modal-content">
      <div class="modal-header">
        <h2 style="font-size: 1.125rem; font-weight: 600;">Quote Request Details</h2>
        <button id="modal-close" class="modal-close-btn">&times;</button>
      </div>
      <div id="modal-body" class="modal-body">
        <p style="color: var(--color-text-tertiary);">Loading...</p>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
// ── Status change via select dropdown ──
document.getElementById('quotes-tbody')?.addEventListener('change', async (e) => {
  const select = e.target as HTMLSelectElement | null;
  if (!select || select.dataset.role !== 'status-select') return;

  const row = select.closest('tr') as HTMLTableRowElement | null;
  if (!row) return;
  const id = row.dataset.id;
  if (!id) return;

  const newStatus = select.value;
  select.disabled = true;

  try {
    const res = await fetch(`/api/quote-requests/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus }),
    });
    if (!res.ok) {
      const data = await res.json().catch(() => ({})) as Record<string, string>;
      alert(data.error || 'Failed to update status');
      // Revert select to previous value
      const badge = row.querySelector('[data-role="status-select"]') as unknown as HTMLSelectElement | null;
      if (badge) badge.value = badge.dataset.prev || 'new';
    }
  } catch {
    alert('Network error');
    const badge2 = row.querySelector('[data-role="status-select"]') as unknown as HTMLSelectElement;
    if (badge2) badge2.value = badge2.dataset.prev || 'new';
  }
});

// Track previous value on focus
document.getElementById('quotes-tbody')?.addEventListener('focusin', (e) => {
  const select = e.target as HTMLSelectElement | null;
  if (!select || select.dataset.role !== 'status-select') return;
  select.dataset.prev = select.value;
  select.disabled = false;
});

// ── View detail modal ──
const modal = document.getElementById('quote-modal') as HTMLDivElement;
const modalBody = document.getElementById('modal-body') as HTMLDivElement;

document.getElementById('quotes-tbody')?.addEventListener('click', async (e) => {
  const btn = (e.target as HTMLElement).closest('button[data-action="view"]') as HTMLButtonElement | null;
  if (!btn) return;

  const row = btn.closest('tr') as HTMLTableRowElement | null;
  if (!row) return;
  const id = row.dataset.id;
  if (!id) return;

  modal.style.display = 'flex';
  modalBody.innerHTML = '<p style="color: var(--color-text-tertiary);">Loading...</p>';

  try {
    const res = await fetch(`/api/quote-requests/${id}`);
    if (!res.ok) {
      modalBody.innerHTML = '<p style="color: var(--color-danger-text);">Failed to load quote details.</p>';
      return;
    }
    const q = await res.json() as Record<string, unknown>;
    const statusColors: Record<string, string> = { new: 'var(--color-info-text)', contacted: 'var(--color-warning-text)', quoted: 'var(--color-brand-600)', closed: 'var(--color-text-tertiary)' };
    const statusColor = statusColors[String(q.status || 'new')] || 'var(--color-text-tertiary)';

    modalBody.innerHTML = `
      <div class="detail-grid">
        <div class="detail-item"><span class="detail-label">Name</span><span>${escHtml(String(q.name || '—'))}</span></div>
        <div class="detail-item"><span class="detail-label">Company</span><span>${escHtml(String(q.company || '—'))}</span></div>
        <div class="detail-item"><span class="detail-label">Email</span><span>${escHtml(String(q.email || '—'))}</span></div>
        <div class="detail-item"><span class="detail-label">Phone</span><span>${escHtml(String(q.phone || '—'))}</span></div>
        <div class="detail-item"><span class="detail-label">Product</span><span>${escHtml(String(q.product || '—'))}</span></div>
        <div class="detail-item"><span class="detail-label">Status</span><span class="detail-badge" style="background:${statusColor};">${String(q.status || 'new')}</span></div>
        <div class="detail-item"><span class="detail-label">Date</span><span>${q.createdAt ? new Date(Number(q.createdAt)).toLocaleString() : '—'}</span></div>
      </div>
      <div class="detail-message">
        <span class="detail-label">Message</span>
        <p style="margin-top: 0.25rem; line-height: 1.6;">${escHtml(String(q.message || '—'))}</p>
      </div>
    `;
  } catch {
    modalBody.innerHTML = '<p style="color: var(--color-danger-text);">Network error.</p>';
  }
});

document.getElementById('modal-close')?.addEventListener('click', () => { modal.style.display = 'none'; });
modal?.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

function escHtml(str: string): string {
  const d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}
</script>

<style>
  .admin-table-wrap { overflow: hidden; border-radius: var(--radius-xl); border: 1px solid var(--color-border); }
  .admin-table { width: 100%; font-size: 0.875rem; border-collapse: collapse; }
  .admin-table thead tr { border-bottom: 1px solid var(--color-border); background: var(--color-surface-subtle); }
  .admin-table th { padding: 0.75rem 1rem; text-align: left; font-weight: 500; }
  .admin-table td { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .admin-table tbody tr:last-child td { border-bottom: none; }
  .empty-cell { padding: 2rem 1rem !important; text-align: center; color: var(--color-text-tertiary); }

  .status-select {
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    cursor: pointer;
  }
  .status-select:disabled { opacity: 0.6; cursor: default; }

  .btn-action {
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .btn-action:hover { background: var(--color-surface-subtle); }
  .btn-view:hover { background: var(--color-info-bg); color: var(--color-info-text); border-color: var(--color-info-border); }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 100;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0,0,0,0.4);
  }
  .modal-content {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    width: 90%; max-width: 36rem;
    max-height: 80vh; overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  .modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .modal-close-btn {
    background: none; border: none; font-size: 1.5rem; cursor: pointer;
    color: var(--color-text-tertiary); line-height: 1; padding: 0;
  }
  .modal-close-btn:hover { color: var(--color-text); }
  .modal-body { padding: 1.25rem; }

  .detail-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem 1.5rem;
  }
  .detail-item {
    display: flex; flex-direction: column; gap: 0.125rem;
  }
  .detail-label {
    font-size: 0.75rem; font-weight: 500; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: 0.025em;
  }
  .detail-badge {
    display: inline-block; padding: 0.125rem 0.5rem; border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 500; color: var(--color-text-inverse); width: fit-content;
  }
  .detail-message {
    margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border-subtle);
  }
</style>
