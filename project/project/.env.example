# ── Environment Variables ──────────────────────────
# Copy this file to .dev.vars for local development.
# Production secrets: use `npx wrangler secret put <NAME>`
#
# Bindings (DB, R2, KV, Queue, Images) are configured in wrangler.jsonc,
# not here. They are listed below for reference only.

# ── Application (set in wrangler.jsonc vars or .dev.vars) ──

# Public site URL. Used for auth trustedOrigins, secure cookies, and SSE CORS.
# In production, must be https://your-domain.com
BETTER_AUTH_URL=http://localhost:4321

# Admin email for receiving quote request and comment notifications.
ADMIN_EMAIL=admin@yourcompany.com

# ── Secrets (use `npx wrangler secret put <NAME>` in production) ──

# Auth session encryption key. REQUIRED in production (min 32 chars).
# Generate with: npx auth secret
# In dev, defaults to 'dev-secret-not-for-production'
# BETTER_AUTH_SECRET=

# Resend API key for sending emails. If unset, emails are logged to console only.
# RESEND_API_KEY=

# Sender email address for notifications. Default: "onboarding@resend.dev"
# EMAIL_FROM=

# ── Optional: Override internal URLs ──

# SSE broadcast URL for queue consumer. Default: http://localhost:8787/api/notifications/stream
# NOTIFICATION_SSE_URL=

# ── Cloudflare Bindings (configured in wrangler.jsonc, NOT here) ──
# These are listed for reference. Do NOT set them in .dev.vars.
#
# DB              — D1 Database (core data store)
# R2              — R2 Bucket (media file storage)
# SESSION         — KV Namespace (auth session storage, auto-provisioned)
# SETTINGS_CACHE  — KV Namespace (site settings cache, auto-provisioned)
# IMAGES          — Cloudflare Images binding (image transformation)
# NOTIFICATION_QUEUE — Cloudflare Queue (async notification processing)
