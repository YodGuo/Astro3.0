{
  "name": "my-b2b-site-astro",
  "type": "module",
  "version": "0.3.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:export": "node scripts/export-build-data.mjs --remote",
    "build:export:local": "node scripts/export-build-data.mjs --local",
    "build:mock": "node scripts/generate-mock-data.mjs && node scripts/inject-theme.mjs",
    "build:theme": "node scripts/inject-theme.mjs",
    "build:full": "node scripts/export-build-data.mjs --remote && astro build",
    "check": "astro check",
    "lint": "eslint src/",
    "preview": "astro preview",
    "astro": "astro",
    "db:migrations:apply": "wrangler d1 migrations apply DB --remote",
    "deploy": "npm run build && npm run db:migrations:apply && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.8",
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@better-auth/passkey": "^1.6.2",
    "@cloudflare/vite-plugin": "^1.25.6",
    "@hookform/resolvers": "^5.2.2",
    "@simplewebauthn/server": "^13.3.0",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "astro": "^6.1.5",
    "better-auth": "^1.6.2",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "resend": "^6.10.0",
    "vite": "^7.3.2",
    "wrangler": "^4.81.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20260410.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
